{
  "name": "medscout-server",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm ci --prefix server && npm run build --prefix server",
    "migrate:deploy": "npm run migrate:deploy --prefix server",
    "start": "npm run start --prefix server",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "client:preview": "npm --prefix client run preview",
    "test:e2e": "npx playwright test",
    "test:e2e:install": "npx playwright install chromium",
    "e2e:fixture:create": "node e2e/helpers/createE2eTestUser.js",
    "e2e:fixture:cleanup": "node e2e/helpers/createE2eTestUser.js --cleanup"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "openai": "^5.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "prisma": "^6.15.0"
  }
}
