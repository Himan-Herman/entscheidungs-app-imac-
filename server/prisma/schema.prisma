model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String
  firstName            String
  lastName             String
  dateOfBirth          DateTime
  verified             Boolean  @default(false)
  verifyToken          String?  @unique
  verifyTokenExpires   DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  passwordResetToken   String?
  passwordResetExpires DateTime?

  profile  UserProfile?
  consent  Consent?
  doctors          Doctor[]
  doctorContacts   DoctorContact[]
  preVisitSessions PreVisitSession[]
  preVisitCases    PreVisitCase[]
  practiceProfiles PracticeProfile[]
  practiceMemberships PracticeMember[]
  practiceInvitesSent PracticeMember[] @relation("PracticeMemberInvitedBy")
  followUpPatientThreads PreVisitFollowUpThread[] @relation("FollowUpPatientUser")
  followUpCreatedThreads PreVisitFollowUpThread[] @relation("FollowUpCreatedByUser")
  visitMedicationEntriesAuthored VisitMedicationEntry[] @relation("VisitMedicationCreatedBy")
  practicePatientLinks           PracticePatientLink[]  @relation("PracticePatientLinks")
  profileAccessGrants            PracticePatientLink[]  @relation("ProfileAccessGrantedBy")
  practiceLinksAsAssignedDoctor  PracticePatientLink[]  @relation("PracticeLinkAssignedDoctor")
  practiceLinksAsAssignedTeam    PracticePatientLink[]  @relation("PracticeLinkAssignedTeam")
  practiceLinksAssignedBy        PracticePatientLink[]  @relation("PracticeLinkAssignedBy")
  practiceLinksPatientDoctorPick PracticePatientLink[] @relation("PracticeLinkPatientSelectedDoctor")
  practicePatientAssignmentsTo   PracticePatientAssignment[] @relation("PracticeAssignmentTo")
  practicePatientAssignmentsBy   PracticePatientAssignment[] @relation("PracticeAssignmentBy")
  patientInboxItems              PatientInboxItem[]
  practicePatientThreads         PracticePatientThread[]
  medicationPlans                MedicationPlan[] @relation("MedicationPlanPatient")
  medicationPlansCreated         MedicationPlan[] @relation("MedicationPlanCreatedBy")
  practiceDocuments              PracticeDocument[] @relation("PracticeDocumentPatient")
  practiceDocumentsCreated       PracticeDocument[] @relation("PracticeDocumentCreatedBy")
  practiceDocumentShares         PracticeDocumentShare[] @relation("PracticeDocumentSharePatient")
  practiceDocumentSharesSharedBy PracticeDocumentShare[] @relation("PracticeDocumentShareBy")
  practiceDocumentsDeleted       PracticeDocument[] @relation("PracticeDocumentDeletedBy")
  practiceDocumentAuditEntries   PracticeDocumentAuditEntry[]
  documentOcrJobsCreated         DocumentOcrJob[] @relation("DocumentOcrJobCreatedBy")
  documentOcrJobsAsPatient       DocumentOcrJob[] @relation("DocumentOcrJobPatient")
  practiceApiClientsCreated      PracticeApiClient[] @relation("PracticeApiClientCreatedBy")
  practiceWebhookEndpointsCreated PracticeWebhookEndpoint[] @relation("PracticeWebhookEndpointCreatedBy")
  patientDataRequests          PatientDataRequest[]
  patientDataRequestsHandled     PatientDataRequest[] @relation("PatientDataRequestHandledBy")
  practiceInboxItemsAsPatient    PracticeInboxItem[]  @relation("PracticeInboxPatient")
  auditLogs        AuditLog[]
  secureDocumentsCreated SecureDocumentDelivery[] @relation("SecureDocCreatedBy")
  secureDocumentAccessTokens SecureDocumentAccessToken[]
  secureDocumentAccessCreated SecureDocumentAccessToken[] @relation("SecureDocAccessCreatedBy")
  patientProfiles      PatientProfile[]
  exportJobs           ExportJob[]
  consentRecords       ConsentRecord[]
  integrationConnectionsCreated IntegrationConnection[] @relation("IntegrationConnectionCreatedBy")
  practiceAppointmentsAsPatient PracticeAppointment[] @relation("PracticeAppointmentPatient")
  practiceAppointmentsCreated   PracticeAppointment[] @relation("PracticeAppointmentCreatedBy")
  practiceAppointmentsCancelled PracticeAppointment[] @relation("PracticeAppointmentCancelledBy")
  telemedicineSessionsAsPatient TelemedicineSession[] @relation("TelemedicinePatient")
  telemedicineSessionsCreated   TelemedicineSession[] @relation("TelemedicineCreatedBy")
  telemedicineParticipants      TelemedicineParticipant[] @relation("TelemedicineParticipantUser")
  telemedicineConsents          TelemedicineConsent[] @relation("TelemedicineConsentPatient")
}

/** Non-medical operational events only — never store transcripts, PDF payloads, or diagnostic text. */
model AuditLog {
  id                    String   @id @default(cuid())
  userId                String?
  actorRole             String?
  action                String
  entityType            String?
  entityId              String?
  practiceProfileId     String?
  patientUserId         String?
  practicePatientLinkId String?
  /// info | warning | security
  severity              String   @default("info")
  /// internal | practice_visible | patient_visible
  visibility            String   @default("internal")
  createdAt             DateTime @default(now())
  ipHash                String?
  userAgent             String?
  metadata              Json?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([practiceProfileId, createdAt])
  @@index([patientUserId, createdAt])
  @@index([practicePatientLinkId, createdAt])
  @@index([visibility, createdAt])
}

/**
 * Privacy-preserving product analytics — salted hashes only, sanitized metadata allowlist.
 * TODO retention: periodically aggregate long-term metrics and prune raw rows older than N days (no medical content stored).
 */
model AnalyticsEvent {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  eventType    String
  userHash     String?
  practiceHash String?
  sessionHash  String?
  metadata     Json?

  @@index([createdAt])
  @@index([practiceHash, eventType])
  @@index([practiceHash, createdAt])
}

/** Groups multiple saved Pre-Visit sessions into a longitudinal / chronic case timeline. */
model PreVisitCase {
  id          String   @id @default(cuid())
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  title       String
  description String?
  category    String?
  isArchived  Boolean  @default(false)

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions PreVisitSession[]

  @@index([userId])
}

model PreVisitSession {
  id             String         @id @default(cuid())
  userId         String
  preVisitCaseId String?
  practiceProfileId String?
  practiceQrTargetId String?
  patientProfileId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patientLanguage String
  doctorLanguage  String?

  title           String?
  status          String   @default("draft")
  practiceStatus  String   @default("new")
  pdfDownloaded   Boolean  @default(false)
  openedAt        DateTime?
  archivedAt      DateTime?
  completedAt     DateTime?
  lastStatusChangeAt DateTime?

  answers         Json
  aiDoctorVersion Json?
  aiSafetyNotice  String?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  preVisitCase PreVisitCase? @relation(fields: [preVisitCaseId], references: [id], onDelete: SetNull)
  practiceProfile PracticeProfile? @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  practiceQrTarget PracticeQrTarget? @relation(fields: [practiceQrTargetId], references: [id], onDelete: SetNull)
  followUpThreads PreVisitFollowUpThread[]
  secureDocumentDeliveries SecureDocumentDelivery[]
  visitMedicationEntries VisitMedicationEntry[]
  patientProfile PatientProfile? @relation(fields: [patientProfileId], references: [id], onDelete: SetNull)

  /// Optional opaque appointment reference (manual text or future external id).
  appointmentReference String?
  /// When set, enables neutral calendar export (.ics) without clinical content.
  appointmentAt DateTime?
  calendarAppointments PracticeAppointment[]

  @@index([userId])
  @@index([preVisitCaseId])
  @@index([practiceProfileId])
  @@index([practiceQrTargetId])
  @@index([patientProfileId])
  @@index([practiceStatus])
  @@index([createdAt])
}


model UserProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  phone      String?
  addressLine String?
  postalCode  String?
  city        String?
  country     String?
  insuranceType String?
  gender      String?
  /// Optional salutation / gender label for forms (non-clinical)
  genderOrSalutation String?
  displayName String?
  preferredPatientLanguage String?
  preferredDoctorLanguage String?
  /// App UI locale (de, en, …) — organizational preference only
  preferredUiLanguage    String?
  /// Free-text emergency contact note — operational only; not medical advice
  emergencyNote String?
  /// Optional health context for Pre-Visit orientation — not a clinical record
  heightCm             Int?
  weightKg             Float?
  allergies            String? @db.Text
  chronicConditions    String? @db.Text
  regularMedications   String? @db.Text
  /// never | former | occasional | daily | prefer_not_say
  smokingStatus        String?
  /// never | occasional | regular | prefer_not_say
  alcoholUse           String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Optional family / dependent profile (caregiver prepares for another person). User must explicitly select.
model PatientProfile {
  id                      String   @id @default(cuid())
  userId                  String
  displayName             String
  relationLabel           String
  dateOfBirth             DateTime?
  genderOrSalutation      String?
  preferredPatientLanguage String?
  preferredDoctorLanguage String?
  isArchived              Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions PreVisitSession[]
  practicePatientLinks PracticePatientLink[]

  @@index([userId])
}

model Consent {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  termsAcceptedAt            DateTime
  privacyAcceptedAt          DateTime
  medicalDisclaimerAcceptedAt DateTime
  doctorAlertConsent         Boolean  @default(false)
}


model Doctor {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/** Address book for Pre-Visit — per authenticated user (managed in Settings). */
model DoctorContact {
  id           String   @id @default(cuid())
  userId       String
  doctorName   String
  practiceName String?
  specialty    String?
  email        String
  phone        String?
  address      String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PracticeProfile {
  id                      String   @id @default(cuid())
  userId                  String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  practiceName            String
  publicSlug              String   @unique
  logoUrl                 String?
  address                 String?
  phone                   String?
  email                   String?
  website                 String?
  specialty               String?
  preferredDoctorLanguage String   @default("de")
  patientIntroText        String?
  description             String?
  city                    String?
  postalCode              String?
  country                 String?
  supportedLanguages      String?
  openingHours            String?
  displayNameForPatients  String?
  accentColor             String?
  logoStorageKey          String?
  logoMimeType            String?
  isActive                Boolean  @default(true)
  /// single_practice | group_practice | mvz | clinic | outpatient | other
  organizationType        String?
  /// JSON array of specialty labels
  specialtiesJson         String?
  stateRegion             String?
  /// yes | no | unknown
  acceptsPublicInsurance    String?
  acceptsPrivateInsurance   String?
  acceptsSelfPay            String?
  emergencyCareAvailable    Boolean?
  onlineAppointmentsAvailable Boolean?
  videoConsultationAvailable  Boolean?
  /// JSON: wheelchair, elevator, accessibleEntrance, accessibleRestroom
  accessibilityJson       String?

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrTargets PracticeQrTarget[]
  members   PracticeMember[]
  preVisitSessions PreVisitSession[]
  followUpThreads PreVisitFollowUpThread[]
  visitMedicationEntries VisitMedicationEntry[]
  practicePatientLinks PracticePatientLink[]
  patientInboxItems    PatientInboxItem[]
  practicePatientThreads PracticePatientThread[]
  medicationPlans        MedicationPlan[]
  practiceDocuments      PracticeDocument[]
  patientDataRequests  PatientDataRequest[]
  practiceInboxItems   PracticeInboxItem[]
  integrationSettings PracticeIntegrationSettings?
  secureDocumentDeliveries SecureDocumentDelivery[]
  secureDocumentAccessTokens SecureDocumentAccessToken[]
  webhookEvents PracticeWebhookEvent[]
  integrationConnections   IntegrationConnection[]
  integrationJobs          IntegrationJob[]
  integrationMappings      IntegrationMapping[]
  externalResourceReferences ExternalResourceReference[]
  appointmentTypes         AppointmentType[]
  practiceAvailabilities   PracticeAvailability[]
  practiceAppointments     PracticeAppointment[]
  telemedicineSettings     PracticeTelemedicineSettings?
  telemedicineSessions     TelemedicineSession[]
  documentOcrJobs          DocumentOcrJob[]
  apiClients               PracticeApiClient[]
  webhookEndpoints         PracticeWebhookEndpoint[]
  webhookDeliveries        PracticeWebhookDelivery[]
  apiAuditEvents           PracticeApiAuditEvent[]

  @@index([userId])
}

/// Practice telemedicine preferences — no provider secrets in DB.
model PracticeTelemedicineSettings {
  id                String   @id @default(cuid())
  practiceProfileId String   @unique
  videoEnabled      Boolean  @default(false)
  /// sandbox | external_link | jitsi | daily | twilio | whereby | zoom | google_meet
  providerType      String   @default("sandbox")
  consentVersion    String   @default("1")
  sandboxMode       Boolean  @default(true)
  externalLinkMode  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
}

/// Organizational video consultation session — no recordings or transcripts.
model TelemedicineSession {
  id                    String    @id @default(cuid())
  appointmentId         String?   @unique
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  providerType          String    @default("sandbox")
  /// planned | waiting | active | completed | cancelled | failed
  status                String    @default("planned")
  title                 String?
  scheduledStartAt      DateTime?
  scheduledEndAt        DateTime?
  startedAt             DateTime?
  endedAt               DateTime?
  joinUrlHash           String?
  hostUrlHash           String?
  providerRoomId        String?
  linkRevokedAt         DateTime?
  consentAcceptedAt     DateTime?
  consentVersion        String?
  createdByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practiceProfile     PracticeProfile      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  appointment         PracticeAppointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  patientUser         User?                @relation("TelemedicinePatient", fields: [patientUserId], references: [id], onDelete: SetNull)
  createdBy           User?                @relation("TelemedicineCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  participants        TelemedicineParticipant[]
  consents            TelemedicineConsent[]

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, scheduledStartAt])
  @@index([patientUserId])
}

model TelemedicineParticipant {
  id        String    @id @default(cuid())
  sessionId String
  userId    String?
  /// patient | practice | guest
  role      String
  /// invited | waiting | joined | left | declined
  status    String    @default("invited")
  joinedAt  DateTime?
  leftAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  session TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?               @relation("TelemedicineParticipantUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId, status])
  @@index([userId])
}

model TelemedicineConsent {
  id              String    @id @default(cuid())
  sessionId       String
  patientUserId   String
  consentVersion  String
  /// granted | revoked
  status          String    @default("granted")
  grantedAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  session     TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  patientUser User                @relation("TelemedicineConsentPatient", fields: [patientUserId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([patientUserId])
}

/// Organizational appointment types — no medical categorization.
model AppointmentType {
  id                String   @id @default(cuid())
  practiceProfileId String
  name              String
  durationMinutes   Int      @default(30)
  color             String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  appointments    PracticeAppointment[]
  availabilities  PracticeAvailability[]

  @@index([practiceProfileId, active])
}

/// Weekly availability windows — organizational scheduling only.
model PracticeAvailability {
  id                String   @id @default(cuid())
  practiceProfileId String
  appointmentTypeId String?
  /// 0=Sunday … 6=Saturday
  weekday           Int
  startTime         String
  endTime           String
  timezone          String   @default("Europe/Berlin")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile  @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  appointmentType AppointmentType? @relation(fields: [appointmentTypeId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, weekday, active])
}

/// Practice appointments — organizational; no clinical triage fields.
model PracticeAppointment {
  id                    String    @id @default(cuid())
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  appointmentTypeId     String?
  preVisitSessionId     String?
  title                 String
  /// requested | scheduled | confirmed | cancelled | completed | no_show | rescheduled
  status                String    @default("scheduled")
  startAt               DateTime
  endAt                 DateTime
  timezone              String    @default("Europe/Berlin")
  /// practice | video | phone | external | unknown
  locationType          String    @default("practice")
  locationText          String?
  patientNote           String?
  practiceNote          String?
  requestedStartAt      DateTime?
  requestedEndAt        DateTime?
  createdByUserId       String?
  cancelledAt           DateTime?
  cancelledByUserId     String?
  cancellationReason    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practiceProfile     PracticeProfile      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  patientUser         User?                @relation("PracticeAppointmentPatient", fields: [patientUserId], references: [id], onDelete: SetNull)
  appointmentType     AppointmentType?     @relation(fields: [appointmentTypeId], references: [id], onDelete: SetNull)
  preVisitSession     PreVisitSession?     @relation(fields: [preVisitSessionId], references: [id], onDelete: SetNull)
  createdBy           User?                @relation("PracticeAppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  cancelledBy         User?                @relation("PracticeAppointmentCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  reminders           AppointmentReminder[]
  telemedicineSession TelemedicineSession?

  @@index([practiceProfileId, startAt])
  @@index([practiceProfileId, status])
  @@index([patientUserId, startAt])
  @@index([practicePatientLinkId])
}

model AppointmentReminder {
  id            String    @id @default(cuid())
  appointmentId String
  /// email | inbox | system
  type          String
  sendAt        DateTime
  /// pending | sent | failed | cancelled
  status        String    @default("pending")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  appointment PracticeAppointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, status])
  @@index([sendAt, status])
}

/// Practice integration preferences — secrets never returned to clients; signing material encrypted at rest.
model PracticeIntegrationSettings {
  id                   String   @id @default(cuid())
  practiceProfileId    String   @unique
  calendarEnabled      Boolean  @default(false)
  /// manual | ics | google_later | microsoft_later
  calendarProvider     String?
  webhookEnabled       Boolean  @default(false)
  webhookUrl           String?
  /// SHA-256 hex of secret (fingerprint only; not used for signing).
  webhookSecretHash    String?
  /// AES-256-GCM encrypted signing secret (see integrationCrypto). Plaintext never stored.
  webhookSecretEnc     String?
  /// download_only | email | secure_portal | webhook
  documentDeliveryMode String   @default("secure_portal")
  secureDownloadEnabled Boolean @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
}

model SecureDocumentDelivery {
  id                String    @id @default(cuid())
  practiceProfileId String
  preVisitSessionId String
  createdByUserId   String
  tokenHash         String    @unique
  expiresAt         DateTime
  downloadedAt      DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  deliveryType      String    @default("secure_link")

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  preVisitSession PreVisitSession @relation(fields: [preVisitSessionId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("SecureDocCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([practiceProfileId])
  @@index([preVisitSessionId])
}

model PracticeWebhookEvent {
  id                String    @id @default(cuid())
  practiceProfileId String
  eventType         String
  payload           Json
  status            String    @default("pending")
  attempts          Int       @default(0)
  lastError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deliveredAt       DateTime?

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)

  @@index([practiceProfileId, status])
  @@index([createdAt])
}

/// PVS/FHIR/HL7 connector configuration — no secrets in configJson; tokens via env/secret store only.
model IntegrationConnection {
  id                String    @id @default(cuid())
  practiceProfileId String
  /// fhir | hl7v2 | pvs | custom
  type              String
  /// fhir_generic | hl7v2_generic | pvs_sandbox | custom_placeholder
  connectorKey      String    @default("custom_placeholder")
  vendorName        String?
  /// disabled | sandbox | active | error | revoked
  status            String    @default("disabled")
  baseUrl           String?
  /// none | api_key | oauth2 | basic | mTLS
  authType          String?   @default("none")
  /// Non-secret config only — never store API keys or tokens here.
  configJson        Json?
  /// R4 | R4B | R5
  fhirVersion       String?   @default("R4")
  createdByUserId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  revokedAt         DateTime?

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("IntegrationConnectionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  jobs            IntegrationJob[]
  mappings        IntegrationMapping[]

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, type])
}

/// Import/export/sync/test jobs — metadata only, no clinical payloads.
model IntegrationJob {
  id                String    @id @default(cuid())
  connectionId      String
  practiceProfileId String
  /// import | export | sync | test
  type              String
  /// inbound | outbound
  direction         String
  /// pending | running | completed | failed | cancelled
  status            String    @default("pending")
  resourceType      String?
  practicePatientLinkId String?
  startedAt         DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  errorCode         String?
  createdAt         DateTime  @default(now())

  connection      IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile       @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)

  @@index([practiceProfileId, createdAt])
  @@index([connectionId, status])
}

model IntegrationMapping {
  id                String   @id @default(cuid())
  practiceProfileId String
  connectionId      String?
  sourceType        String
  targetType        String
  mappingJson       Json
  version           String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile        @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  connection      IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, active])
  @@index([connectionId])
}

/// Cross-system resource IDs — no clinical content.
model ExternalResourceReference {
  id                    String   @id @default(cuid())
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  localResourceType     String
  localResourceId       String
  externalSystemType    String
  externalResourceType  String
  externalResourceId    String
  externalVersion       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)

  @@index([practiceProfileId, localResourceType, localResourceId])
  @@index([practicePatientLinkId])
  @@index([externalSystemType, externalResourceId])
}

model PracticeQrTarget {
  id                      String   @id @default(cuid())
  practiceProfileId       String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  targetName              String
  targetType              String   @default("practice")
  doctorName              String?
  specialty               String?
  recipientEmail          String?
  preferredDoctorLanguage String?
  qrToken                 String   @unique
  isActive                Boolean  @default(true)

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  preVisitSessions PreVisitSession[]
  followUpThreads PreVisitFollowUpThread[]

  @@index([practiceProfileId])
}

model PracticeMember {
  id                String    @id @default(cuid())
  practiceProfileId String
  userId            String
  role              String
  /// invited | active | revoked
  status            String    @default("active")
  invitedByUserId   String?
  invitedAt         DateTime?
  acceptedAt        DateTime?
  revokedAt         DateTime?
  displayName       String?
  positionTitle     String?
  specialty         String?
  languagesJson     String?
  visibleToPatients Boolean  @default(false)
  acceptsPatientRequests Boolean @default(true)
  doctorTitle       String?
  focusArea         String?
  officeHours       String?
  internalContact   String?
  onlineAppointmentsAvailable Boolean?
  videoConsultationAvailable Boolean?
  lastActiveAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy       User?           @relation("PracticeMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([practiceProfileId, userId])
  @@index([userId])
  @@index([practiceProfileId, role])
  @@index([practiceProfileId, status])
}

model PreVisitFollowUpThread {
  id                     String   @id @default(cuid())
  preVisitSessionId      String
  practiceProfileId      String?
  qrTargetId             String?
  patientUserId          String?
  createdByUserId        String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  status                 String   @default("open")
  title                  String?
  isArchived             Boolean  @default(false)
  followUpAccessToken    String?  @unique
  followUpTokenExpiresAt DateTime?

  session        PreVisitSession          @relation(fields: [preVisitSessionId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile?        @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  qrTarget       PracticeQrTarget?        @relation(fields: [qrTargetId], references: [id], onDelete: SetNull)
  patientUser    User?                    @relation("FollowUpPatientUser", fields: [patientUserId], references: [id], onDelete: SetNull)
  createdByUser  User?                    @relation("FollowUpCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages       PreVisitFollowUpMessage[]

  @@index([preVisitSessionId])
  @@index([practiceProfileId, status])
  @@index([patientUserId, status])
  @@index([updatedAt])
}

model PreVisitFollowUpMessage {
  id           String   @id @default(cuid())
  threadId     String
  senderType   String
  senderUserId String?
  body         String
  createdAt    DateTime @default(now())
  readAt       DateTime?

  thread      PreVisitFollowUpThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

/**
 * Explicit care relationship between a practice and a patient account (or dependent profile).
 * Central anchor for medication, messaging, and documents in later phases — not tied to a single PreVisitSession.
 */
model PracticePatientLink {
  id                String    @id @default(cuid())
  practiceProfileId String
  patientUserId     String
  patientProfileId  String?
  /// invited | active | revoked | archived
  status            String    @default("invited")
  linkedAt          DateTime  @default(now())
  revokedAt         DateTime?
  consentVersion    String?
  consentAcceptedAt DateTime?
  /// Accepted scopes, e.g. ["medication","messages","profile"] — set by patient consent API.
  consentScopes     Json?
  profileAccessGrantedAt   DateTime?
  profileAccessRevokedAt   DateTime?
  profileAccessGrantedByUserId String?
  /// unassigned | assigned | forwarded | closed
  assignmentStatus          String    @default("unassigned")
  assignedDoctorUserId      String?
  assignedTeamMemberUserId  String?
  assignedByUserId          String?
  assignedAt                DateTime?
  assignmentNote            String?
  lastForwardedAt           DateTime?
  patientSelectedDoctorUserId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser     User            @relation("PracticePatientLinks", fields: [patientUserId], references: [id], onDelete: Cascade)
  profileAccessGrantedBy User?    @relation("ProfileAccessGrantedBy", fields: [profileAccessGrantedByUserId], references: [id], onDelete: SetNull)
  assignedDoctor  User?           @relation("PracticeLinkAssignedDoctor", fields: [assignedDoctorUserId], references: [id], onDelete: SetNull)
  assignedTeamMember User?        @relation("PracticeLinkAssignedTeam", fields: [assignedTeamMemberUserId], references: [id], onDelete: SetNull)
  assignedBy      User?           @relation("PracticeLinkAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  patientSelectedDoctor User?     @relation("PracticeLinkPatientSelectedDoctor", fields: [patientSelectedDoctorUserId], references: [id], onDelete: SetNull)
  patientProfile  PatientProfile? @relation(fields: [patientProfileId], references: [id], onDelete: SetNull)
  assignments     PracticePatientAssignment[]
  inboxItems      PatientInboxItem[]
  threads         PracticePatientThread[]
  medicationPlans MedicationPlan[]
  practiceDocuments PracticeDocument[]
  dataRequests      PatientDataRequest[]
  practiceInboxItems PracticeInboxItem[]
  secureDocumentAccessTokens SecureDocumentAccessToken[]
  appointments               PracticeAppointment[]
  telemedicineSessions       TelemedicineSession[]
  documentOcrJobs            DocumentOcrJob[]

  @@unique([practiceProfileId, patientUserId, patientProfileId])
  @@index([practiceProfileId, status])
  @@index([patientUserId, status])
  @@index([linkedAt])
  @@index([practiceProfileId, assignmentStatus])
  @@index([practiceProfileId, assignedDoctorUserId])
  @@index([practiceProfileId, assignedTeamMemberUserId])
}

/// Organizational assignment history for a practice–patient link (no clinical content).
model PracticePatientAssignment {
  id                    String    @id @default(cuid())
  practicePatientLinkId String
  assignedToUserId      String
  assignedByUserId      String?
  /// doctor | secretary | assistant | team
  assignmentType        String
  /// active | revoked | forwarded
  status                String    @default("active")
  note                  String?
  createdAt             DateTime  @default(now())
  revokedAt             DateTime?

  practicePatientLink PracticePatientLink @relation(fields: [practicePatientLinkId], references: [id], onDelete: Cascade)
  assignedTo          User                @relation("PracticeAssignmentTo", fields: [assignedToUserId], references: [id], onDelete: Cascade)
  assignedBy          User?               @relation("PracticeAssignmentBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([practicePatientLinkId, createdAt])
  @@index([assignedToUserId, status])
}

/**
 * Neutral patient inbox entry — no clinical content in title/summary (operational notice only).
 */
model PatientInboxItem {
  id                    String    @id @default(cuid())
  patientUserId         String
  practiceProfileId     String?
  practicePatientLinkId String?
  /// medication | message | document | profile | data_request | system
  type                  String
  title                 String
  titleKey              String?
  summary               String?
  summaryKey            String?
  /// unread | read | archived
  status                String    @default("unread")
  sourceLabel           String?
  targetUrl             String?
  createdAt             DateTime  @default(now())
  readAt                DateTime?
  archivedAt            DateTime?

  patientUser         User                 @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile?     @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)

  @@index([patientUserId, status])
  @@index([patientUserId, createdAt])
  @@index([practiceProfileId])
}

/**
 * Practice-side operational inbox — neutral titles/summaries only in list; no clinical scoring.
 */
model PracticeInboxItem {
  id                    String    @id @default(cuid())
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  /// message | previsit | follow_up | document | medication | profile | data_request | system
  type                  String
  title                 String
  titleKey              String?
  summary               String?
  summaryKey            String?
  /// new | read | done | archived
  status                String    @default("new")
  /// normal | important — organizational only, not clinical urgency
  priority              String    @default("normal")
  sourceRefType         String?
  sourceRefId           String?
  targetUrl             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastActivityAt        DateTime  @default(now())
  readAt                DateTime?
  doneAt                DateTime?
  archivedAt            DateTime?

  practiceProfile     PracticeProfile      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  patientUser         User?                @relation("PracticeInboxPatient", fields: [patientUserId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, type])
  @@index([practiceProfileId, lastActivityAt])
  @@index([practiceProfileId, sourceRefType, sourceRefId])
}

/** Secure messaging thread tied to a practice–patient link (no anonymous threads). */
model PracticePatientThread {
  id                    String    @id @default(cuid())
  practicePatientLinkId String
  practiceProfileId     String
  patientUserId         String
  subject               String?
  /// open | closed | archived
  status                String    @default("open")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  closedAt              DateTime?
  archivedAt            DateTime?

  practicePatientLink PracticePatientLink @relation(fields: [practicePatientLinkId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile     @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser         User                @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  messages            PracticePatientMessage[]

  @@index([practicePatientLinkId, status])
  @@index([patientUserId, status])
  @@index([practiceProfileId, updatedAt])
}

model PracticePatientMessage {
  id           String    @id @default(cuid())
  threadId     String
  /// practice | patient | system
  senderType   String
  senderUserId String?
  body         String
  createdAt    DateTime  @default(now())
  readAt       DateTime?

  thread PracticePatientThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

/**
 * Relationship-based medication plan (v2) — practice-provided only, versioned.
 */
model MedicationPlan {
  id                    String    @id @default(cuid())
  practicePatientLinkId String
  practiceProfileId     String
  patientUserId         String
  /// draft | published | archived | deleted
  status                String    @default("draft")
  version               Int       @default(1)
  title                 String?
  note                  String?
  createdByUserId       String?
  publishedAt           DateTime?
  archivedAt            DateTime?
  deletedAt             DateTime?
  deletedByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practicePatientLink PracticePatientLink @relation(fields: [practicePatientLinkId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile     @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser         User                @relation("MedicationPlanPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  createdBy           User?               @relation("MedicationPlanCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items               MedicationPlanItem[]

  @@index([practicePatientLinkId, status])
  @@index([patientUserId, status])
  @@index([practiceProfileId, version])
}

model MedicationPlanItem {
  id               String    @id @default(cuid())
  medicationPlanId String
  medicationName   String
  dosage           String?
  frequency        String?
  route            String?
  schedule         String?
  startDate        DateTime?
  endDate          DateTime?
  instructions     String?
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  medicationPlan MedicationPlan @relation(fields: [medicationPlanId], references: [id], onDelete: Cascade)

  @@index([medicationPlanId, sortOrder])
}

/**
 * Practice-provided document for a care link — files stored externally (storageKey only).
 */
model PracticeDocument {
  id                    String    @id @default(cuid())
  practicePatientLinkId String
  practiceProfileId     String
  patientUserId         String
  /// report | lab | imaging | referral | discharge | prescription_info | other
  type                  String    @default("other")
  title                 String
  description           String?
  /// draft | shared | archived | deleted
  status                String    @default("draft")
  createdByUserId       String?
  sharedAt              DateTime?
  archivedAt            DateTime?
  deletedAt             DateTime?
  deletedByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practicePatientLink PracticePatientLink @relation(fields: [practicePatientLinkId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile     @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser         User                @relation("PracticeDocumentPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  createdBy           User?               @relation("PracticeDocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deletedBy           User?               @relation("PracticeDocumentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  files               PracticeDocumentFile[]
  shares              PracticeDocumentShare[]
  secureAccessTokens  SecureDocumentAccessToken[]
  ocrJobs             DocumentOcrJob[]
  ocrResults          DocumentOcrResult[]
  labStructuredEntries LabStructuredEntry[]

  @@index([practicePatientLinkId, status])
  @@index([patientUserId, status])
  @@index([practiceProfileId, createdAt])
}

model PracticeDocumentFile {
  id               String   @id @default(cuid())
  documentId       String
  storageKey       String
  originalFileName String
  mimeType         String
  sizeBytes        Int
  checksum         String?
  createdAt        DateTime @default(now())

  document PracticeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  secureAccessTokens SecureDocumentAccessToken[]
  ocrJobs            DocumentOcrJob[]

  @@index([documentId])
}

/// OCR / lab structuring job — metadata only in audit; no clinical payloads in logs.
model DocumentOcrJob {
  id                    String    @id @default(cuid())
  documentId            String
  fileId                String
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  /// pending | running | completed | failed | cancelled
  status                String    @default("pending")
  /// local_stub | external_ocr | ai_vision | manual
  engine                String    @default("local_stub")
  startedAt             DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  errorCode             String?
  createdByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  document            PracticeDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file                PracticeDocumentFile  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile       @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  practicePatientLink PracticePatientLink?  @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  patientUser         User?                 @relation("DocumentOcrJobPatient", fields: [patientUserId], references: [id], onDelete: SetNull)
  createdBy           User?                 @relation("DocumentOcrJobCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  result              DocumentOcrResult?
  labEntries          LabStructuredEntry[]

  @@index([documentId, status])
  @@index([practiceProfileId, createdAt])
}

model DocumentOcrResult {
  id                      String   @id @default(cuid())
  ocrJobId                String   @unique
  documentId              String
  /// detected | needs_review | reviewed | shared | discarded
  reviewStatus            String   @default("needs_review")
  extractedTextStorageKey String?
  structuredJson          Json?
  confidence              Float?
  language                String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  ocrJob   DocumentOcrJob   @relation(fields: [ocrJobId], references: [id], onDelete: Cascade)
  document PracticeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, reviewStatus])
}

/// Lab table row — no interpretation, normal/abnormal, or risk fields.
model LabStructuredEntry {
  id                 String    @id @default(cuid())
  documentId         String
  ocrJobId           String?
  label              String
  valueText          String
  unit               String?
  referenceRangeText String?
  collectedAt        DateTime?
  sourcePage         Int?
  sourceLine         Int?
  confidence         Float?
  createdAt          DateTime  @default(now())

  document PracticeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ocrJob   DocumentOcrJob?  @relation(fields: [ocrJobId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([ocrJobId])
}

/// Machine API client — token stored as hash only.
model PracticeApiClient {
  id                String    @id @default(cuid())
  practiceProfileId String
  name              String
  /// active | revoked | disabled
  status            String    @default("active")
  tokenHash         String    @unique
  scopesJson        Json
  createdByUserId   String?
  lastUsedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("PracticeApiClientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  auditEvents     PracticeApiAuditEvent[]

  @@index([practiceProfileId, status])
}

/// Developer webhook endpoint (multi-endpoint per practice).
model PracticeWebhookEndpoint {
  id                String    @id @default(cuid())
  practiceProfileId String
  name              String
  url               String
  /// active | paused | revoked
  status            String    @default("active")
  secretHash        String
  secretEnc         String?
  eventTypesJson    Json
  createdByUserId   String?
  lastSuccessAt     DateTime?
  lastFailureAt     DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile PracticeProfile         @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User?                   @relation("PracticeWebhookEndpointCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deliveries      PracticeWebhookDelivery[]

  @@index([practiceProfileId, status])
}

/// Webhook delivery attempt log — no payload bodies.
model PracticeWebhookDelivery {
  id                String    @id @default(cuid())
  endpointId        String
  practiceProfileId String
  eventType         String
  /// pending | delivered | failed | retrying | cancelled
  status            String    @default("pending")
  attemptCount      Int       @default(0)
  lastStatusCode    Int?
  lastErrorCode     String?
  nextRetryAt       DateTime?
  deliveredAt       DateTime?
  eventId           String    @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  endpoint        PracticeWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile         @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([practiceProfileId, createdAt])
  @@index([nextRetryAt])
}

/// External API access audit — metadata only.
model PracticeApiAuditEvent {
  id                String   @id @default(cuid())
  practiceProfileId String
  apiClientId       String?
  action            String
  endpoint          String?
  statusCode        Int?
  ipHash            String?
  createdAt         DateTime @default(now())

  practiceProfile PracticeProfile  @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  apiClient       PracticeApiClient? @relation(fields: [apiClientId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, createdAt])
  @@index([apiClientId])
}

/**
 * Short-lived hashed token for secure practice document download (no public storage URLs).
 */
model SecureDocumentAccessToken {
  id                    String    @id @default(cuid())
  documentId            String
  fileId                String?
  tokenHash             String    @unique
  /// patient | practice
  audience              String
  userId                String?
  practiceProfileId     String?
  practicePatientLinkId String?
  createdByUserId       String?
  expiresAt             DateTime
  usedAt                DateTime?
  revokedAt             DateTime?
  createdAt             DateTime  @default(now())

  document            PracticeDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file                PracticeDocumentFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  user                User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  practiceProfile     PracticeProfile?      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  practicePatientLink PracticePatientLink?  @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  createdBy           User?                 @relation("SecureDocAccessCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([practiceProfileId])
  @@index([expiresAt])
}

model PracticeDocumentShare {
  id             String    @id @default(cuid())
  documentId     String
  patientUserId  String
  sharedByUserId String?
  /// active | revoked
  status         String    @default("active")
  sharedAt       DateTime  @default(now())
  revokedAt      DateTime?
  expiresAt      DateTime?

  document   PracticeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  patientUser User            @relation("PracticeDocumentSharePatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  sharedBy    User?           @relation("PracticeDocumentShareBy", fields: [sharedByUserId], references: [id], onDelete: SetNull)

  @@index([documentId, status])
  @@index([patientUserId, status])
}

/**
 * Operational audit for practice documents — metadata only, no clinical content.
 */
model PracticeDocumentAuditEntry {
  id                String   @id @default(cuid())
  actorUserId       String
  /// practice | patient | system
  actorRole         String
  practiceProfileId String?
  patientUserId     String?
  /// practice_document | document_file | document_share
  resourceType      String
  resourceId        String
  /// deleted | archived | share_revoked | file_deleted
  action            String
  reason            String?
  metadataJson      Json?
  createdAt         DateTime @default(now())

  actorUser User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([resourceType, resourceId])
  @@index([practiceProfileId, createdAt])
  @@index([patientUserId, createdAt])
}

/**
 * Patient-initiated data control request (deletion, access restriction, export).
 */
model PatientDataRequest {
  id                    String    @id @default(cuid())
  patientUserId         String
  practiceProfileId     String?
  practicePatientLinkId String?
  /// deletion | access_restriction | export
  type                  String
  /// submitted | in_review | completed | rejected
  status                String    @default("submitted")
  reason                String?
  /// Practice response — organizational only, no clinical content.
  responseNote          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  completedAt           DateTime?
  handledByUserId       String?

  patientUser         User                 @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile?     @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  handledBy           User?                @relation("PatientDataRequestHandledBy", fields: [handledByUserId], references: [id], onDelete: SetNull)

  @@index([patientUserId, createdAt])
  @@index([practiceProfileId, status])
  @@index([practicePatientLinkId])
}

/** Practice-entered medication / intake plan after a visit — not AI-generated. */
model VisitMedicationEntry {
  id                 String    @id @default(cuid())
  preVisitSessionId  String
  practiceProfileId  String
  createdByUserId    String
  drugName           String
  dosage             String?
  frequency          String
  intakeInstructions String?
  sortOrder          Int       @default(0)
  publishedAt        DateTime?
  patientViewedAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  session         PreVisitSession @relation(fields: [preVisitSessionId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("VisitMedicationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([preVisitSessionId, publishedAt])
  @@index([practiceProfileId])
  @@index([createdByUserId])
}

/**
 * Server-generated export artifacts — metadata only on row; file bytes in storageKey.
 */
model ExportJob {
  id                    String    @id @default(cuid())
  requestedByUserId     String
  /// patient | practice | system
  actorRole             String
  practiceProfileId     String?
  patientUserId         String?
  practicePatientLinkId String?
  /// export type slug (medication_plans, patient_summary, …)
  type                  String
  /// pdf | csv
  format                String
  /// pending | completed | failed | expired
  status                String    @default("pending")
  storageKey            String?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  completedAt           DateTime?
  failedAt              DateTime?
  errorCode             String?

  requestedBy User @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([requestedByUserId, createdAt])
  @@index([patientUserId, createdAt])
  @@index([practiceProfileId, createdAt])
  @@index([practicePatientLinkId])
  @@index([status, expiresAt])
}

/**
 * Granular patient consent per practice link — organizational purposes only.
 */
model ConsentRecord {
  id                    String    @id @default(cuid())
  patientUserId         String
  practiceProfileId     String?
  practicePatientLinkId String?
  consentType           String
  /// granted | revoked | expired
  status                String    @default("granted")
  grantedAt             DateTime  @default(now())
  revokedAt             DateTime?
  expiresAt             DateTime?
  grantedByUserId       String?
  revokedByUserId       String?
  version               String?
  metadataJson          Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  patientUser User @relation(fields: [patientUserId], references: [id], onDelete: Cascade)

  @@index([patientUserId, createdAt])
  @@index([practiceProfileId, consentType])
  @@index([practicePatientLinkId, consentType, status])
  @@index([status, expiresAt])
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
