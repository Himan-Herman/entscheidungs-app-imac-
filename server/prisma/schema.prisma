model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  firstName            String
  lastName             String
  dateOfBirth          DateTime
  verified             Boolean   @default(false)
  verifyToken          String?   @unique
  verifyTokenExpires   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  passwordResetToken   String?
  passwordResetExpires DateTime?

  profile                          UserProfile?
  consent                          Consent?
  doctors                          Doctor[]
  doctorContacts                   DoctorContact[]
  preVisitSessions                 PreVisitSession[]
  preVisitCases                    PreVisitCase[]
  practiceProfiles                 PracticeProfile[]
  practiceMemberships              PracticeMember[]
  practiceInvitesSent              PracticeMember[]                 @relation("PracticeMemberInvitedBy")
  followUpPatientThreads           PreVisitFollowUpThread[]         @relation("FollowUpPatientUser")
  followUpCreatedThreads           PreVisitFollowUpThread[]         @relation("FollowUpCreatedByUser")
  visitMedicationEntriesAuthored   VisitMedicationEntry[]           @relation("VisitMedicationCreatedBy")
  practicePatientLinks             PracticePatientLink[]            @relation("PracticePatientLinks")
  profileAccessGrants              PracticePatientLink[]            @relation("ProfileAccessGrantedBy")
  practiceLinksAsAssignedDoctor    PracticePatientLink[]            @relation("PracticeLinkAssignedDoctor")
  practiceLinksAsAssignedTeam      PracticePatientLink[]            @relation("PracticeLinkAssignedTeam")
  practiceLinksAssignedBy          PracticePatientLink[]            @relation("PracticeLinkAssignedBy")
  practiceLinksPatientDoctorPick   PracticePatientLink[]            @relation("PracticeLinkPatientSelectedDoctor")
  practicePatientAssignmentsTo     PracticePatientAssignment[]      @relation("PracticeAssignmentTo")
  practicePatientAssignmentsBy     PracticePatientAssignment[]      @relation("PracticeAssignmentBy")
  patientInboxItems                PatientInboxItem[]
  practicePatientThreads           PracticePatientThread[]
  medicationPlans                  MedicationPlan[]                 @relation("MedicationPlanPatient")
  medicationPlansCreated           MedicationPlan[]                 @relation("MedicationPlanCreatedBy")
  practiceDocuments                PracticeDocument[]               @relation("PracticeDocumentPatient")
  practiceDocumentsCreated         PracticeDocument[]               @relation("PracticeDocumentCreatedBy")
  practiceDocumentShares           PracticeDocumentShare[]          @relation("PracticeDocumentSharePatient")
  practiceDocumentSharesSharedBy   PracticeDocumentShare[]          @relation("PracticeDocumentShareBy")
  practiceDocumentsDeleted         PracticeDocument[]               @relation("PracticeDocumentDeletedBy")
  practiceDocumentAuditEntries     PracticeDocumentAuditEntry[]
  documentOcrJobsCreated           DocumentOcrJob[]                 @relation("DocumentOcrJobCreatedBy")
  documentOcrJobsAsPatient         DocumentOcrJob[]                 @relation("DocumentOcrJobPatient")
  practiceApiClientsCreated        PracticeApiClient[]              @relation("PracticeApiClientCreatedBy")
  practiceWebhookEndpointsCreated  PracticeWebhookEndpoint[]        @relation("PracticeWebhookEndpointCreatedBy")
  patientDataRequests              PatientDataRequest[]
  patientDataRequestsHandled       PatientDataRequest[]             @relation("PatientDataRequestHandledBy")
  practiceInboxItemsAsPatient      PracticeInboxItem[]              @relation("PracticeInboxPatient")
  auditLogs                        AuditLog[]
  secureDocumentsCreated           SecureDocumentDelivery[]         @relation("SecureDocCreatedBy")
  secureDocumentAccessTokens       SecureDocumentAccessToken[]
  secureDocumentAccessCreated      SecureDocumentAccessToken[]      @relation("SecureDocAccessCreatedBy")
  patientProfiles                  PatientProfile[]
  exportJobs                       ExportJob[]
  consentRecords                   ConsentRecord[]
  integrationConnectionsCreated    IntegrationConnection[]          @relation("IntegrationConnectionCreatedBy")
  practiceAppointmentsAsPatient    PracticeAppointment[]            @relation("PracticeAppointmentPatient")
  practiceAppointmentsCreated      PracticeAppointment[]            @relation("PracticeAppointmentCreatedBy")
  practiceAppointmentsCancelled    PracticeAppointment[]            @relation("PracticeAppointmentCancelledBy")
  telemedicineSessionsAsPatient    TelemedicineSession[]            @relation("TelemedicinePatient")
  telemedicineSessionsCreated      TelemedicineSession[]            @relation("TelemedicineCreatedBy")
  telemedicineParticipants         TelemedicineParticipant[]        @relation("TelemedicineParticipantUser")
  telemedicineConsents             TelemedicineConsent[]            @relation("TelemedicineConsentPatient")
  interpreterCloudPreference       InterpreterCloudPreference?
  interpreterCloudSessions         InterpreterCloudSession[]
  interpreterCloudSessionPayloads  InterpreterCloudSessionPayload[]
  interpreterInvitesCreated        PracticeInterpreterInvite[]      @relation("InterpreterInviteCreatedBy")
  interpreterInvitesRevoked        PracticeInterpreterInvite[]      @relation("InterpreterInviteRevokedBy")
  anamnesisLinksCreated            PracticeAnamnesisLink[]          @relation("AnamnesisLinkCreatedBy")
  interpreterSessionLinksAsPatient PracticeInterpreterSessionLink[] @relation("InterpreterSessionLinkPatient")
  interpreterSessionLinksRevoked   PracticeInterpreterSessionLink[] @relation("InterpreterSessionLinkRevokedBy")
  vaccinationEntries               VaccinationEntry[]
  vitalEntries                     VitalEntry[]
  allergyEntries                   AllergyEntry[]
  diagnosisEntries                 DiagnosisEntry[]
  erezeptEntries                   ErezeptEntry[]                   @relation("PatientErezept")
  issuedErezeptEntries             ErezeptEntry[]                   @relation("PracticeErezept")
  sosCard                          SosCard?
}

/**
 * Non-medical operational events only — never store transcripts, PDF payloads, or diagnostic text.
 */
model AuditLog {
  id                    String   @id @default(cuid())
  userId                String?
  actorRole             String?
  action                String
  entityType            String?
  entityId              String?
  practiceProfileId     String?
  patientUserId         String?
  practicePatientLinkId String?
  /// info | warning | security
  severity              String   @default("info")
  /// internal | practice_visible | patient_visible
  visibility            String   @default("internal")
  createdAt             DateTime @default(now())
  ipHash                String?
  userAgent             String?
  metadata              Json?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([practiceProfileId, createdAt])
  @@index([patientUserId, createdAt])
  @@index([practicePatientLinkId, createdAt])
  @@index([visibility, createdAt])
}

/**
 * Privacy-preserving product analytics — salted hashes only, sanitized metadata allowlist.
 * TODO retention: periodically aggregate long-term metrics and prune raw rows older than N days (no medical content stored).
 */
model AnalyticsEvent {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  eventType    String
  userHash     String?
  practiceHash String?
  sessionHash  String?
  metadata     Json?

  @@index([createdAt])
  @@index([practiceHash, eventType])
  @@index([practiceHash, createdAt])
}

/**
 * Groups multiple saved Pre-Visit sessions into a longitudinal / chronic case timeline.
 */
model PreVisitCase {
  id          String   @id @default(cuid())
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  title       String
  description String?
  category    String?
  isArchived  Boolean  @default(false)

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions PreVisitSession[]

  @@index([userId])
}

model PreVisitSession {
  id                 String   @id @default(cuid())
  userId             String
  preVisitCaseId     String?
  practiceProfileId  String?
  practiceQrTargetId String?
  patientProfileId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  patientLanguage String
  doctorLanguage  String?

  title              String?
  status             String    @default("draft")
  practiceStatus     String    @default("new")
  pdfDownloaded      Boolean   @default(false)
  openedAt           DateTime?
  archivedAt         DateTime?
  completedAt        DateTime?
  lastStatusChangeAt DateTime?

  answers         Json
  aiDoctorVersion Json?
  aiSafetyNotice  String?

  user                     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preVisitCase             PreVisitCase?            @relation(fields: [preVisitCaseId], references: [id], onDelete: SetNull)
  practiceProfile          PracticeProfile?         @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  practiceQrTarget         PracticeQrTarget?        @relation(fields: [practiceQrTargetId], references: [id], onDelete: SetNull)
  followUpThreads          PreVisitFollowUpThread[]
  secureDocumentDeliveries SecureDocumentDelivery[]
  visitMedicationEntries   VisitMedicationEntry[]
  patientProfile           PatientProfile?          @relation(fields: [patientProfileId], references: [id], onDelete: SetNull)

  /// Optional opaque appointment reference (manual text or future external id).
  appointmentReference String?
  /// When set, enables neutral calendar export (.ics) without clinical content.
  appointmentAt        DateTime?
  calendarAppointments PracticeAppointment[]

  @@index([userId])
  @@index([preVisitCaseId])
  @@index([practiceProfileId])
  @@index([practiceQrTargetId])
  @@index([patientProfileId])
  @@index([practiceStatus])
  @@index([createdAt])
}

model UserProfile {
  id                       String  @id @default(cuid())
  userId                   String  @unique
  phone                    String?
  addressLine              String?
  postalCode               String?
  city                     String?
  country                  String?
  insuranceType            String?
  gender                   String?
  /// Optional salutation / gender label for forms (non-clinical)
  genderOrSalutation       String?
  displayName              String?
  preferredPatientLanguage String?
  preferredDoctorLanguage  String?
  /// App UI locale (de, en, …) — organizational preference only
  preferredUiLanguage      String?
  /// Free-text emergency contact note — operational only; not medical advice
  emergencyNote            String?
  /// Optional health context for Pre-Visit orientation — not a clinical record
  heightCm                 Int?
  weightKg                 Float?
  allergies                String? @db.Text
  chronicConditions        String? @db.Text
  regularMedications       String? @db.Text
  /// never | former | occasional | daily | prefer_not_say
  smokingStatus            String?
  /// never | occasional | regular | prefer_not_say
  alcoholUse               String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Optional family / dependent profile (caregiver prepares for another person). User must explicitly select.
model PatientProfile {
  id                       String    @id @default(cuid())
  userId                   String
  displayName              String
  relationLabel            String
  dateOfBirth              DateTime?
  genderOrSalutation       String?
  preferredPatientLanguage String?
  preferredDoctorLanguage  String?
  isArchived               Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions             PreVisitSession[]
  practicePatientLinks PracticePatientLink[]

  @@index([userId])
}

model Consent {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  termsAcceptedAt             DateTime
  privacyAcceptedAt           DateTime
  medicalDisclaimerAcceptedAt DateTime
  doctorAlertConsent          Boolean  @default(false)
}

model Doctor {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * Address book for Pre-Visit — per authenticated user (managed in Settings).
 */
model DoctorContact {
  id           String   @id @default(cuid())
  userId       String
  doctorName   String
  practiceName String?
  specialty    String?
  email        String
  phone        String?
  address      String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PracticeProfile {
  id                            String   @id @default(cuid())
  userId                        String
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  practiceName                  String
  publicSlug                    String   @unique
  logoUrl                       String?
  address                       String?
  phone                         String?
  email                         String?
  website                       String?
  specialty                     String?
  preferredDoctorLanguage       String   @default("de")
  patientIntroText              String?
  description                   String?
  city                          String?
  postalCode                    String?
  country                       String?
  supportedLanguages            String?
  openingHours                  String?
  displayNameForPatients        String?
  accentColor                   String?
  logoStorageKey                String?
  logoMimeType                  String?
  isActive                      Boolean  @default(true)
  /// single_practice | group_practice | mvz | clinic | outpatient | other
  organizationType              String?
  /// JSON array of specialty labels
  specialtiesJson               String?
  stateRegion                   String?
  /// yes | no | unknown
  acceptsPublicInsurance        String?
  acceptsPrivateInsurance       String?
  acceptsSelfPay                String?
  emergencyCareAvailable        Boolean?
  onlineAppointmentsAvailable   Boolean?
  videoConsultationAvailable    Boolean?
  /// JSON: wheelchair, elevator, accessibleEntrance, accessibleRestroom
  accessibilityJson             String?
  /// Official registered legal name of the practice (if different from display name)
  legalName                     String?
  /// Street and house number — separate from combined address field
  street                        String?
  /// Preferred interpreter/translation languages as JSON array string, e.g. ["tr","ar","ru"]
  preferredInterpreterLanguages String?
  /// Enables the Praxis-Anamnese module for this practice (verified practices only).
  anamnesisEnabled              Boolean  @default(false)

  user                       User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrTargets                  PracticeQrTarget[]
  members                    PracticeMember[]
  preVisitSessions           PreVisitSession[]
  followUpThreads            PreVisitFollowUpThread[]
  visitMedicationEntries     VisitMedicationEntry[]
  practicePatientLinks       PracticePatientLink[]
  patientInboxItems          PatientInboxItem[]
  practicePatientThreads     PracticePatientThread[]
  medicationPlans            MedicationPlan[]
  practiceDocuments          PracticeDocument[]
  patientDataRequests        PatientDataRequest[]
  practiceInboxItems         PracticeInboxItem[]
  integrationSettings        PracticeIntegrationSettings?
  secureDocumentDeliveries   SecureDocumentDelivery[]
  secureDocumentAccessTokens SecureDocumentAccessToken[]
  webhookEvents              PracticeWebhookEvent[]
  integrationConnections     IntegrationConnection[]
  integrationJobs            IntegrationJob[]
  integrationMappings        IntegrationMapping[]
  externalResourceReferences ExternalResourceReference[]
  appointmentTypes           AppointmentType[]
  practiceAvailabilities     PracticeAvailability[]
  practiceAppointments       PracticeAppointment[]
  telemedicineSettings       PracticeTelemedicineSettings?
  telemedicineSessions       TelemedicineSession[]
  documentOcrJobs            DocumentOcrJob[]
  apiClients                 PracticeApiClient[]
  webhookEndpoints           PracticeWebhookEndpoint[]
  webhookDeliveries          PracticeWebhookDelivery[]
  apiAuditEvents             PracticeApiAuditEvent[]
  interpreterInvites         PracticeInterpreterInvite[]
  interpreterSessionLinks    PracticeInterpreterSessionLink[]
  medaSessions               PracticeMedaSession[]
  anamnesisTemplates         PracticeAnamnesisTemplate[]
  anamnesisLinks             PracticeAnamnesisLink[]
  anamnesisSubmissions       PracticeAnamnesisSubmission[]
  bookingSettings            PracticeBookingSettings?

  @@index([userId])
}

/// Practice telemedicine preferences — no provider secrets in DB.
model PracticeTelemedicineSettings {
  id                String   @id @default(cuid())
  practiceProfileId String   @unique
  videoEnabled      Boolean  @default(false)
  /// sandbox | external_link | jitsi | daily | twilio | whereby | zoom | google_meet
  providerType      String   @default("sandbox")
  consentVersion    String   @default("1")
  sandboxMode       Boolean  @default(true)
  externalLinkMode  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
}

/// Organizational video consultation session — no recordings or transcripts.
model TelemedicineSession {
  id                    String    @id @default(cuid())
  appointmentId         String?   @unique
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  providerType          String    @default("sandbox")
  /// planned | waiting | active | completed | cancelled | failed
  status                String    @default("planned")
  title                 String?
  scheduledStartAt      DateTime?
  scheduledEndAt        DateTime?
  startedAt             DateTime?
  endedAt               DateTime?
  joinUrlHash           String?
  hostUrlHash           String?
  providerRoomId        String?
  linkRevokedAt         DateTime?
  consentAcceptedAt     DateTime?
  consentVersion        String?
  createdByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practiceProfile     PracticeProfile           @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  appointment         PracticeAppointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  practicePatientLink PracticePatientLink?      @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  patientUser         User?                     @relation("TelemedicinePatient", fields: [patientUserId], references: [id], onDelete: SetNull)
  createdBy           User?                     @relation("TelemedicineCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  participants        TelemedicineParticipant[]
  consents            TelemedicineConsent[]

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, scheduledStartAt])
  @@index([patientUserId])
}

model TelemedicineParticipant {
  id        String    @id @default(cuid())
  sessionId String
  userId    String?
  /// patient | practice | guest
  role      String
  /// invited | waiting | joined | left | declined
  status    String    @default("invited")
  joinedAt  DateTime?
  leftAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  session TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?               @relation("TelemedicineParticipantUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId, status])
  @@index([userId])
}

model TelemedicineConsent {
  id             String    @id @default(cuid())
  sessionId      String
  patientUserId  String
  consentVersion String
  /// granted | revoked
  status         String    @default("granted")
  grantedAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  session     TelemedicineSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  patientUser User                @relation("TelemedicineConsentPatient", fields: [patientUserId], references: [id], onDelete: Cascade)

  @@index([sessionId, status])
  @@index([patientUserId])
}

/// Organizational appointment types — no medical categorization.
model AppointmentType {
  id                String   @id @default(cuid())
  practiceProfileId String
  name              String
  durationMinutes   Int      @default(30)
  color             String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile        @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  appointments    PracticeAppointment[]
  availabilities  PracticeAvailability[]

  @@index([practiceProfileId, active])
}

/// Weekly availability windows — organizational scheduling only.
model PracticeAvailability {
  id                String   @id @default(cuid())
  practiceProfileId String
  appointmentTypeId String?
  /// 0=Sunday … 6=Saturday
  weekday           Int
  startTime         String
  endTime           String
  timezone          String   @default("Europe/Berlin")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile  @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  appointmentType AppointmentType? @relation(fields: [appointmentTypeId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, weekday, active])
}

/// Practice appointments — organizational; no clinical triage fields.
model PracticeAppointment {
  id                      String    @id @default(cuid())
  practiceProfileId       String
  practicePatientLinkId   String?
  patientUserId           String?
  appointmentTypeId       String?
  preVisitSessionId       String?
  title                   String
  /// requested | scheduled | confirmed | cancelled | completed | no_show | rescheduled
  status                  String    @default("scheduled")
  startAt                 DateTime
  endAt                   DateTime
  timezone                String    @default("Europe/Berlin")
  /// practice | video | phone | external | unknown
  locationType            String    @default("practice")
  locationText            String?
  patientNote             String?
  practiceNote            String?
  requestedStartAt        DateTime?
  requestedEndAt          DateTime?
  createdByUserId         String?
  cancelledAt             DateTime?
  cancelledByUserId       String?
  cancellationReason      String?
  /// BCP-47 UI locale at request time — used for organisational email templates only (de|en|fr|it|es).
  communicationLocale     String?   @db.VarChar(5)
  /// Timestamp when patient actively granted consent for this request — server-set only.
  requestConsentGrantedAt DateTime?
  /// Consent document version accepted by patient (e.g. "booking-v1").
  requestConsentVersion   String?   @db.VarChar(20)
  /// Scope string identifying the consent purpose (e.g. "appointment_request").
  requestConsentScope     String?   @db.VarChar(100)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  practiceProfile     PracticeProfile       @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  practicePatientLink PracticePatientLink?  @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  patientUser         User?                 @relation("PracticeAppointmentPatient", fields: [patientUserId], references: [id], onDelete: SetNull)
  appointmentType     AppointmentType?      @relation(fields: [appointmentTypeId], references: [id], onDelete: SetNull)
  preVisitSession     PreVisitSession?      @relation(fields: [preVisitSessionId], references: [id], onDelete: SetNull)
  createdBy           User?                 @relation("PracticeAppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  cancelledBy         User?                 @relation("PracticeAppointmentCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  reminders           AppointmentReminder[]
  telemedicineSession TelemedicineSession?

  @@index([practiceProfileId, startAt])
  @@index([practiceProfileId, status])
  @@index([patientUserId, startAt])
  @@index([practicePatientLinkId])
}

model AppointmentReminder {
  id               String    @id @default(cuid())
  /// Stable idempotency key (e.g. appt:{id}:inbox:24h).
  reminderKey      String    @unique
  /// appointment | follow_up
  subjectKind      String    @default("appointment")
  appointmentId    String?
  followUpThreadId String?
  /// email | inbox | system
  type             String
  /// Copy template — no clinical content in DB.
  templateKey      String
  sendAt           DateTime
  /// pending | processing | sent | failed | cancelled
  status           String    @default("pending")
  attemptCount     Int       @default(0)
  maxAttempts      Int       @default(5)
  nextRetryAt      DateTime?
  failedReason     String?
  sentAt           DateTime?
  processingAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  appointment    PracticeAppointment?    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  followUpThread PreVisitFollowUpThread? @relation(fields: [followUpThreadId], references: [id], onDelete: Cascade)

  @@index([appointmentId, status])
  @@index([sendAt, status])
  @@index([status, sendAt, nextRetryAt])
  @@index([followUpThreadId, status])
}

/// Practice integration preferences — secrets never returned to clients; signing material encrypted at rest.
model PracticeIntegrationSettings {
  id                    String   @id @default(cuid())
  practiceProfileId     String   @unique
  calendarEnabled       Boolean  @default(false)
  /// manual | ics | google_later | microsoft_later
  calendarProvider      String?
  webhookEnabled        Boolean  @default(false)
  webhookUrl            String?
  /// SHA-256 hex of secret (fingerprint only; not used for signing).
  webhookSecretHash     String?
  /// AES-256-GCM encrypted signing secret (see integrationCrypto). Plaintext never stored.
  webhookSecretEnc      String?
  /// download_only | email | secure_portal | webhook
  documentDeliveryMode  String   @default("secure_portal")
  secureDownloadEnabled Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
}

model SecureDocumentDelivery {
  id                String    @id @default(cuid())
  practiceProfileId String
  preVisitSessionId String
  createdByUserId   String
  tokenHash         String    @unique
  expiresAt         DateTime
  downloadedAt      DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  deliveryType      String    @default("secure_link")

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  preVisitSession PreVisitSession @relation(fields: [preVisitSessionId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("SecureDocCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([practiceProfileId])
  @@index([preVisitSessionId])
}

model PracticeWebhookEvent {
  id                String    @id @default(cuid())
  practiceProfileId String
  eventType         String
  payload           Json
  /// pending | processing | delivered | retrying | failed | dead_letter | skipped
  status            String    @default("pending")
  attempts          Int       @default(0)
  lastError         String?
  lastStatusCode    Int?
  nextRetryAt       DateTime?
  processingAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deliveredAt       DateTime?

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)

  @@index([practiceProfileId, status])
  @@index([createdAt])
  @@index([status, nextRetryAt])
}

/// PVS/FHIR/HL7 connector configuration — no secrets in configJson; tokens via env/secret store only.
model IntegrationConnection {
  id                String    @id @default(cuid())
  practiceProfileId String
  /// fhir | hl7v2 | pvs | custom
  type              String
  /// fhir_generic | hl7v2_generic | pvs_sandbox | custom_placeholder
  connectorKey      String    @default("custom_placeholder")
  vendorName        String?
  /// disabled | sandbox | active | error | revoked
  status            String    @default("disabled")
  baseUrl           String?
  /// none | api_key | oauth2 | basic | mTLS
  authType          String?   @default("none")
  /// Non-secret config only — never store API keys or tokens here.
  configJson        Json?
  /// R4 | R4B | R5
  fhirVersion       String?   @default("R4")
  createdByUserId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  revokedAt         DateTime?

  practiceProfile PracticeProfile      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User?                @relation("IntegrationConnectionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  jobs            IntegrationJob[]
  mappings        IntegrationMapping[]

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, type])
}

/// Import/export/sync/test jobs — metadata only, no clinical payloads.
model IntegrationJob {
  id                    String    @id @default(cuid())
  connectionId          String
  practiceProfileId     String
  /// import | export | sync | test
  type                  String
  /// inbound | outbound
  direction             String
  /// pending | running | completed | failed | cancelled
  status                String    @default("pending")
  resourceType          String?
  practicePatientLinkId String?
  startedAt             DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  errorCode             String?
  createdAt             DateTime  @default(now())

  connection      IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile       @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)

  @@index([practiceProfileId, createdAt])
  @@index([connectionId, status])
}

model IntegrationMapping {
  id                String   @id @default(cuid())
  practiceProfileId String
  connectionId      String?
  sourceType        String
  targetType        String
  mappingJson       Json
  version           String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile        @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  connection      IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, active])
  @@index([connectionId])
}

/// Cross-system resource IDs — no clinical content.
model ExternalResourceReference {
  id                    String   @id @default(cuid())
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  localResourceType     String
  localResourceId       String
  externalSystemType    String
  externalResourceType  String
  externalResourceId    String
  externalVersion       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)

  @@index([practiceProfileId, localResourceType, localResourceId])
  @@index([practicePatientLinkId])
  @@index([externalSystemType, externalResourceId])
}

model PracticeQrTarget {
  id                      String   @id @default(cuid())
  practiceProfileId       String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  targetName              String
  targetType              String   @default("practice")
  doctorName              String?
  specialty               String?
  recipientEmail          String?
  preferredDoctorLanguage String?
  qrToken                 String   @unique
  isActive                Boolean  @default(true)

  practiceProfile  PracticeProfile          @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  preVisitSessions PreVisitSession[]
  followUpThreads  PreVisitFollowUpThread[]

  @@index([practiceProfileId])
}

model PracticeMember {
  id                          String    @id @default(cuid())
  practiceProfileId           String
  userId                      String
  role                        String
  /// invited | active | revoked
  status                      String    @default("active")
  invitedByUserId             String?
  invitedAt                   DateTime?
  acceptedAt                  DateTime?
  revokedAt                   DateTime?
  displayName                 String?
  positionTitle               String?
  specialty                   String?
  languagesJson               String?
  visibleToPatients           Boolean   @default(false)
  acceptsPatientRequests      Boolean   @default(true)
  doctorTitle                 String?
  focusArea                   String?
  officeHours                 String?
  internalContact             String?
  onlineAppointmentsAvailable Boolean?
  videoConsultationAvailable  Boolean?
  lastActiveAt                DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy       User?           @relation("PracticeMemberInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([practiceProfileId, userId])
  @@index([userId])
  @@index([practiceProfileId, role])
  @@index([practiceProfileId, status])
}

model PreVisitFollowUpThread {
  id                     String    @id @default(cuid())
  preVisitSessionId      String
  practiceProfileId      String?
  qrTargetId             String?
  patientUserId          String?
  createdByUserId        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  status                 String    @default("open")
  title                  String?
  isArchived             Boolean   @default(false)
  followUpAccessToken    String?   @unique
  followUpTokenExpiresAt DateTime?

  session              PreVisitSession           @relation(fields: [preVisitSessionId], references: [id], onDelete: Cascade)
  practiceProfile      PracticeProfile?          @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  qrTarget             PracticeQrTarget?         @relation(fields: [qrTargetId], references: [id], onDelete: SetNull)
  patientUser          User?                     @relation("FollowUpPatientUser", fields: [patientUserId], references: [id], onDelete: SetNull)
  createdByUser        User?                     @relation("FollowUpCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages             PreVisitFollowUpMessage[]
  appointmentReminders AppointmentReminder[]

  @@index([preVisitSessionId])
  @@index([practiceProfileId, status])
  @@index([patientUserId, status])
  @@index([updatedAt])
}

model PreVisitFollowUpMessage {
  id           String    @id @default(cuid())
  threadId     String
  senderType   String
  senderUserId String?
  body         String
  createdAt    DateTime  @default(now())
  readAt       DateTime?

  thread PreVisitFollowUpThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

/**
 * Explicit care relationship between a practice and a patient account (or dependent profile).
 * Central anchor for medication, messaging, and documents in later phases — not tied to a single PreVisitSession.
 */
model PracticePatientLink {
  id                           String    @id @default(cuid())
  practiceProfileId            String
  patientUserId                String
  patientProfileId             String?
  /// invited | active | revoked | archived
  status                       String    @default("invited")
  linkedAt                     DateTime  @default(now())
  revokedAt                    DateTime?
  consentVersion               String?
  consentAcceptedAt            DateTime?
  /// Accepted scopes, e.g. ["medication","messages","profile"] — set by patient consent API.
  consentScopes                Json?
  profileAccessGrantedAt       DateTime?
  profileAccessRevokedAt       DateTime?
  profileAccessGrantedByUserId String?
  /// unassigned | assigned | forwarded | closed
  assignmentStatus             String    @default("unassigned")
  assignedDoctorUserId         String?
  assignedTeamMemberUserId     String?
  assignedByUserId             String?
  assignedAt                   DateTime?
  assignmentNote               String?
  lastForwardedAt              DateTime?
  patientSelectedDoctorUserId  String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  practiceProfile            PracticeProfile             @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser                User                        @relation("PracticePatientLinks", fields: [patientUserId], references: [id], onDelete: Cascade)
  profileAccessGrantedBy     User?                       @relation("ProfileAccessGrantedBy", fields: [profileAccessGrantedByUserId], references: [id], onDelete: SetNull)
  assignedDoctor             User?                       @relation("PracticeLinkAssignedDoctor", fields: [assignedDoctorUserId], references: [id], onDelete: SetNull)
  assignedTeamMember         User?                       @relation("PracticeLinkAssignedTeam", fields: [assignedTeamMemberUserId], references: [id], onDelete: SetNull)
  assignedBy                 User?                       @relation("PracticeLinkAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  patientSelectedDoctor      User?                       @relation("PracticeLinkPatientSelectedDoctor", fields: [patientSelectedDoctorUserId], references: [id], onDelete: SetNull)
  patientProfile             PatientProfile?             @relation(fields: [patientProfileId], references: [id], onDelete: SetNull)
  assignments                PracticePatientAssignment[]
  inboxItems                 PatientInboxItem[]
  threads                    PracticePatientThread[]
  medicationPlans            MedicationPlan[]
  practiceDocuments          PracticeDocument[]
  dataRequests               PatientDataRequest[]
  practiceInboxItems         PracticeInboxItem[]
  secureDocumentAccessTokens SecureDocumentAccessToken[]
  appointments               PracticeAppointment[]
  telemedicineSessions       TelemedicineSession[]
  documentOcrJobs            DocumentOcrJob[]
  medaSessions               PracticeMedaSession[]

  @@unique([practiceProfileId, patientUserId, patientProfileId])
  @@index([practiceProfileId, status])
  @@index([patientUserId, status])
  @@index([linkedAt])
  @@index([practiceProfileId, assignmentStatus])
  @@index([practiceProfileId, assignedDoctorUserId])
  @@index([practiceProfileId, assignedTeamMemberUserId])
}

/// Organizational assignment history for a practice–patient link (no clinical content).
model PracticePatientAssignment {
  id                    String    @id @default(cuid())
  practicePatientLinkId String
  assignedToUserId      String
  assignedByUserId      String?
  /// doctor | secretary | assistant | team
  assignmentType        String
  /// active | revoked | forwarded
  status                String    @default("active")
  note                  String?
  createdAt             DateTime  @default(now())
  revokedAt             DateTime?

  practicePatientLink PracticePatientLink @relation(fields: [practicePatientLinkId], references: [id], onDelete: Cascade)
  assignedTo          User                @relation("PracticeAssignmentTo", fields: [assignedToUserId], references: [id], onDelete: Cascade)
  assignedBy          User?               @relation("PracticeAssignmentBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([practicePatientLinkId, createdAt])
  @@index([assignedToUserId, status])
}

/**
 * Neutral patient inbox entry — no clinical content in title/summary (operational notice only).
 */
model PatientInboxItem {
  id                    String    @id @default(cuid())
  patientUserId         String
  practiceProfileId     String?
  practicePatientLinkId String?
  /// medication | message | document | profile | data_request | system
  type                  String
  title                 String
  titleKey              String?
  summary               String?
  summaryKey            String?
  /// unread | read | archived
  status                String    @default("unread")
  sourceLabel           String?
  targetUrl             String?
  /// Dedupe source (e.g. practice_document, medication_plan, patient_thread).
  sourceRefType         String?
  sourceRefId           String?
  /// Stable key: type:sourceRefType:sourceRefId[:titleKey]
  dedupeKey             String?
  lastActivityAt        DateTime?
  createdAt             DateTime  @default(now())
  readAt                DateTime?
  archivedAt            DateTime?

  patientUser         User                 @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile?     @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)

  @@unique([patientUserId, dedupeKey])
  @@index([patientUserId, status])
  @@index([patientUserId, createdAt])
  @@index([patientUserId, lastActivityAt])
  @@index([patientUserId, sourceRefType, sourceRefId])
  @@index([practiceProfileId])
}

/**
 * Practice-side operational inbox — neutral titles/summaries only in list; no clinical scoring.
 */
model PracticeInboxItem {
  id                    String    @id @default(cuid())
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  /// message | previsit | follow_up | document | medication | profile | data_request | system
  type                  String
  title                 String
  titleKey              String?
  summary               String?
  summaryKey            String?
  /// new | read | done | archived
  status                String    @default("new")
  /// normal | important — organizational only, not clinical urgency
  priority              String    @default("normal")
  sourceRefType         String?
  sourceRefId           String?
  targetUrl             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastActivityAt        DateTime  @default(now())
  readAt                DateTime?
  doneAt                DateTime?
  archivedAt            DateTime?

  practiceProfile     PracticeProfile      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  patientUser         User?                @relation("PracticeInboxPatient", fields: [patientUserId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, type])
  @@index([practiceProfileId, lastActivityAt])
  @@index([practiceProfileId, sourceRefType, sourceRefId])
}

/**
 * Secure messaging thread tied to a practice–patient link (no anonymous threads).
 */
model PracticePatientThread {
  id                    String    @id @default(cuid())
  practicePatientLinkId String
  practiceProfileId     String
  patientUserId         String
  subject               String?
  /// open | closed | archived
  status                String    @default("open")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  closedAt              DateTime?
  archivedAt            DateTime?

  practicePatientLink PracticePatientLink      @relation(fields: [practicePatientLinkId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile          @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser         User                     @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  messages            PracticePatientMessage[]

  @@index([practicePatientLinkId, status])
  @@index([patientUserId, status])
  @@index([practiceProfileId, updatedAt])
}

model PracticePatientMessage {
  id           String    @id @default(cuid())
  threadId     String
  /// practice | patient | system
  senderType   String
  senderUserId String?
  body         String
  createdAt    DateTime  @default(now())
  readAt       DateTime?

  thread PracticePatientThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

/**
 * Relationship-based medication plan (v2) — practice-provided only, versioned.
 */
model MedicationPlan {
  id                    String    @id @default(cuid())
  practicePatientLinkId String
  practiceProfileId     String
  patientUserId         String
  /// draft | published | archived | deleted
  status                String    @default("draft")
  version               Int       @default(1)
  title                 String?
  note                  String?
  createdByUserId       String?
  publishedAt           DateTime?
  archivedAt            DateTime?
  deletedAt             DateTime?
  deletedByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practicePatientLink PracticePatientLink  @relation(fields: [practicePatientLinkId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser         User                 @relation("MedicationPlanPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  createdBy           User?                @relation("MedicationPlanCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items               MedicationPlanItem[]

  @@index([practicePatientLinkId, status])
  @@index([patientUserId, status])
  @@index([practiceProfileId, version])
}

model MedicationPlanItem {
  id               String    @id @default(cuid())
  medicationPlanId String
  medicationName   String
  dosage           String?
  frequency        String?
  route            String?
  schedule         String?
  startDate        DateTime?
  endDate          DateTime?
  instructions     String?
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  medicationPlan MedicationPlan @relation(fields: [medicationPlanId], references: [id], onDelete: Cascade)

  @@index([medicationPlanId, sortOrder])
}

/**
 * Practice-provided document for a care link — files stored externally (storageKey only).
 */
model PracticeDocument {
  id                    String    @id @default(cuid())
  // Nullable since the Meda PDF-QR flow stores practice-owned PDFs for sessions
  // that may involve an unregistered, unlinked patient. Patient-linked documents
  // continue to set both fields; onDelete: Cascade is preserved for those.
  practicePatientLinkId String?
  practiceProfileId     String
  patientUserId         String?
  /// report | lab | imaging | referral | discharge | prescription_info | other
  type                  String    @default("other")
  title                 String
  description           String?
  /// draft | shared | archived | deleted
  status                String    @default("draft")
  createdByUserId       String?
  sharedAt              DateTime?
  archivedAt            DateTime?
  deletedAt             DateTime?
  deletedByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  practicePatientLink  PracticePatientLink?        @relation(fields: [practicePatientLinkId], references: [id], onDelete: Cascade)
  practiceProfile      PracticeProfile             @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser          User?                       @relation("PracticeDocumentPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  createdBy            User?                       @relation("PracticeDocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deletedBy            User?                       @relation("PracticeDocumentDeletedBy", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  files                PracticeDocumentFile[]
  shares               PracticeDocumentShare[]
  secureAccessTokens   SecureDocumentAccessToken[]
  ocrJobs              DocumentOcrJob[]
  ocrResults           DocumentOcrResult[]
  labStructuredEntries LabStructuredEntry[]

  @@index([practicePatientLinkId, status])
  @@index([patientUserId, status])
  @@index([practiceProfileId, createdAt])
}

model PracticeDocumentFile {
  id               String   @id @default(cuid())
  documentId       String
  storageKey       String
  originalFileName String
  mimeType         String
  sizeBytes        Int
  checksum         String?
  createdAt        DateTime @default(now())

  document           PracticeDocument            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  secureAccessTokens SecureDocumentAccessToken[]
  ocrJobs            DocumentOcrJob[]

  @@index([documentId])
}

/// OCR / lab structuring job — metadata only in audit; no clinical payloads in logs.
model DocumentOcrJob {
  id                    String    @id @default(cuid())
  documentId            String
  fileId                String
  practiceProfileId     String
  practicePatientLinkId String?
  patientUserId         String?
  /// pending | processing | running | completed | failed | cancelled
  status                String    @default("pending")
  /// local_stub | external_ocr | ai_vision | manual
  engine                String    @default("local_stub")
  attemptCount          Int       @default(0)
  nextRetryAt           DateTime?
  processingAt          DateTime?
  locale                String?
  startedAt             DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  errorCode             String?
  createdByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  document            PracticeDocument     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file                PracticeDocumentFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  patientUser         User?                @relation("DocumentOcrJobPatient", fields: [patientUserId], references: [id], onDelete: SetNull)
  createdBy           User?                @relation("DocumentOcrJobCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  result              DocumentOcrResult?
  labEntries          LabStructuredEntry[]

  @@index([documentId, status])
  @@index([practiceProfileId, createdAt])
  @@index([status, nextRetryAt])
}

model DocumentOcrResult {
  id                      String   @id @default(cuid())
  ocrJobId                String   @unique
  documentId              String
  /// detected | needs_review | reviewed | shared | discarded
  reviewStatus            String   @default("needs_review")
  extractedTextStorageKey String?
  structuredJson          Json?
  confidence              Float?
  language                String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  ocrJob   DocumentOcrJob   @relation(fields: [ocrJobId], references: [id], onDelete: Cascade)
  document PracticeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, reviewStatus])
}

/// Lab table row — no interpretation, normal/abnormal, or risk fields.
model LabStructuredEntry {
  id                 String    @id @default(cuid())
  documentId         String
  ocrJobId           String?
  label              String
  valueText          String
  unit               String?
  referenceRangeText String?
  collectedAt        DateTime?
  sourcePage         Int?
  sourceLine         Int?
  confidence         Float?
  createdAt          DateTime  @default(now())

  document PracticeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  ocrJob   DocumentOcrJob?  @relation(fields: [ocrJobId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([ocrJobId])
}

/// Machine API client — token stored as hash only.
model PracticeApiClient {
  id                String    @id @default(cuid())
  practiceProfileId String
  name              String
  /// active | revoked | disabled
  status            String    @default("active")
  tokenHash         String    @unique
  scopesJson        Json
  createdByUserId   String?
  lastUsedAt        DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile PracticeProfile         @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User?                   @relation("PracticeApiClientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  auditEvents     PracticeApiAuditEvent[]

  @@index([practiceProfileId, status])
}

/// Developer webhook endpoint (multi-endpoint per practice).
model PracticeWebhookEndpoint {
  id                String    @id @default(cuid())
  practiceProfileId String
  name              String
  url               String
  /// active | paused | revoked
  status            String    @default("active")
  secretHash        String
  secretEnc         String?
  eventTypesJson    Json
  createdByUserId   String?
  lastSuccessAt     DateTime?
  lastFailureAt     DateTime?
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile PracticeProfile           @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User?                     @relation("PracticeWebhookEndpointCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  deliveries      PracticeWebhookDelivery[]

  @@index([practiceProfileId, status])
}

/// Webhook delivery attempt log — no payload bodies.
model PracticeWebhookDelivery {
  id                String    @id @default(cuid())
  endpointId        String
  practiceProfileId String
  eventType         String
  /// pending | processing | delivered | retrying | failed | dead_letter | cancelled
  status            String    @default("pending")
  attemptCount      Int       @default(0)
  maxAttempts       Int       @default(5)
  lastStatusCode    Int?
  lastErrorCode     String?
  nextRetryAt       DateTime?
  processingAt      DateTime?
  deliveredAt       DateTime?
  /// Metadata-only payload snapshot for delivery (no clinical text).
  payloadJson       Json?
  eventId           String    @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  endpoint        PracticeWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile         @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@index([practiceProfileId, createdAt])
  @@index([nextRetryAt])
  @@index([status, nextRetryAt])
}

/// External API access audit — metadata only.
model PracticeApiAuditEvent {
  id                String   @id @default(cuid())
  practiceProfileId String
  apiClientId       String?
  action            String
  endpoint          String?
  statusCode        Int?
  ipHash            String?
  createdAt         DateTime @default(now())

  practiceProfile PracticeProfile    @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  apiClient       PracticeApiClient? @relation(fields: [apiClientId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, createdAt])
  @@index([apiClientId])
}

/**
 * Short-lived hashed token for secure practice document download (no public storage URLs).
 */
model SecureDocumentAccessToken {
  id                    String    @id @default(cuid())
  documentId            String
  fileId                String?
  tokenHash             String    @unique
  /// patient | practice
  audience              String
  userId                String?
  practiceProfileId     String?
  practicePatientLinkId String?
  createdByUserId       String?
  expiresAt             DateTime
  usedAt                DateTime?
  revokedAt             DateTime?
  createdAt             DateTime  @default(now())

  document            PracticeDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  file                PracticeDocumentFile? @relation(fields: [fileId], references: [id], onDelete: SetNull)
  user                User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  practiceProfile     PracticeProfile?      @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  practicePatientLink PracticePatientLink?  @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  createdBy           User?                 @relation("SecureDocAccessCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([practiceProfileId])
  @@index([expiresAt])
}

model PracticeDocumentShare {
  id             String    @id @default(cuid())
  documentId     String
  patientUserId  String
  sharedByUserId String?
  /// active | revoked
  status         String    @default("active")
  sharedAt       DateTime  @default(now())
  revokedAt      DateTime?
  expiresAt      DateTime?

  document    PracticeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  patientUser User             @relation("PracticeDocumentSharePatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  sharedBy    User?            @relation("PracticeDocumentShareBy", fields: [sharedByUserId], references: [id], onDelete: SetNull)

  @@index([documentId, status])
  @@index([patientUserId, status])
}

/**
 * Operational audit for practice documents — metadata only, no clinical content.
 */
model PracticeDocumentAuditEntry {
  id                String   @id @default(cuid())
  actorUserId       String
  /// practice | patient | system
  actorRole         String
  practiceProfileId String?
  patientUserId     String?
  /// practice_document | document_file | document_share
  resourceType      String
  resourceId        String
  /// deleted | archived | share_revoked | file_deleted
  action            String
  reason            String?
  metadataJson      Json?
  createdAt         DateTime @default(now())

  actorUser User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([resourceType, resourceId])
  @@index([practiceProfileId, createdAt])
  @@index([patientUserId, createdAt])
}

/**
 * Patient-initiated data control request (deletion, access restriction, export).
 */
model PatientDataRequest {
  id                    String    @id @default(cuid())
  patientUserId         String
  practiceProfileId     String?
  practicePatientLinkId String?
  /// deletion | access_restriction | export
  type                  String
  /// submitted | in_review | completed | rejected
  status                String    @default("submitted")
  reason                String?
  /// Practice response — organizational only, no clinical content.
  responseNote          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  completedAt           DateTime?
  handledByUserId       String?

  patientUser         User                 @relation(fields: [patientUserId], references: [id], onDelete: Cascade)
  practiceProfile     PracticeProfile?     @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)
  handledBy           User?                @relation("PatientDataRequestHandledBy", fields: [handledByUserId], references: [id], onDelete: SetNull)

  @@index([patientUserId, createdAt])
  @@index([practiceProfileId, status])
  @@index([practicePatientLinkId])
}

/**
 * Practice-entered medication / intake plan after a visit — not AI-generated.
 */
model VisitMedicationEntry {
  id                 String    @id @default(cuid())
  preVisitSessionId  String
  practiceProfileId  String
  createdByUserId    String
  drugName           String
  dosage             String?
  frequency          String
  intakeInstructions String?
  sortOrder          Int       @default(0)
  publishedAt        DateTime?
  patientViewedAt    DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  session         PreVisitSession @relation(fields: [preVisitSessionId], references: [id], onDelete: Cascade)
  practiceProfile PracticeProfile @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("VisitMedicationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([preVisitSessionId, publishedAt])
  @@index([practiceProfileId])
  @@index([createdByUserId])
}

/**
 * Server-generated export artifacts — metadata only on row; file bytes in storageKey.
 */
model ExportJob {
  id                    String    @id @default(cuid())
  requestedByUserId     String
  /// patient | practice | system
  actorRole             String
  practiceProfileId     String?
  patientUserId         String?
  practicePatientLinkId String?
  /// export type slug (medication_plans, patient_summary, …)
  type                  String
  /// pdf | csv
  format                String
  /// pending | processing | completed | failed | expired | cancelled
  status                String    @default("pending")
  storageKey            String?
  expiresAt             DateTime?
  attemptCount          Int       @default(0)
  nextRetryAt           DateTime?
  processingAt          DateTime?
  locale                String?
  createdAt             DateTime  @default(now())
  completedAt           DateTime?
  failedAt              DateTime?
  errorCode             String?

  requestedBy User @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([requestedByUserId, createdAt])
  @@index([patientUserId, createdAt])
  @@index([practiceProfileId, createdAt])
  @@index([practicePatientLinkId])
  @@index([status, expiresAt])
  @@index([status, nextRetryAt])
}

/**
 * Granular patient consent per practice link — organizational purposes only.
 */
model ConsentRecord {
  id                    String    @id @default(cuid())
  patientUserId         String
  practiceProfileId     String?
  practicePatientLinkId String?
  consentType           String
  /// granted | revoked | expired
  status                String    @default("granted")
  grantedAt             DateTime  @default(now())
  revokedAt             DateTime?
  expiresAt             DateTime?
  grantedByUserId       String?
  revokedByUserId       String?
  version               String?
  metadataJson          Json?
  /// Consent capture channel — patient_app | practice_app | paper | imported
  source                String?   @db.VarChar(40)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  patientUser User @relation(fields: [patientUserId], references: [id], onDelete: Cascade)

  @@index([patientUserId, createdAt])
  @@index([practiceProfileId, consentType])
  @@index([practicePatientLinkId, consentType, status])
  @@index([status, expiresAt])
}

/// B2C Medical Interpreter — optional encrypted cloud storage (explicit consent only).
model InterpreterCloudPreference {
  id               String    @id @default(cuid())
  userId           String    @unique
  cloudEnabled     Boolean   @default(false)
  consentVersion   String?
  consentGrantedAt DateTime?
  consentRevokedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Session metadata (plaintext organizational fields only).
/// Turn text is stored encrypted in InterpreterCloudSessionPayload (not per-row turns table).
model InterpreterCloudSession {
  id                  String    @id @default(cuid())
  userId              String
  /// Optional org/practice scope for future enterprise features — never grants practice access.
  organizationId      String?
  practiceProfileId   String?
  /// Client-side session UUID (InterpreterSession.sessionId).
  clientSessionId     String
  status              String
  patientLanguage     String    @db.VarChar(12)
  doctorLanguage      String    @db.VarChar(12)
  conversationTitle   String?   @db.VarChar(200)
  doctorName          String?   @db.VarChar(120)
  practiceName        String?   @db.VarChar(120)
  specialty           String?   @db.VarChar(120)
  appointmentDateTime DateTime?
  profileConsentUsed  Boolean   @default(false)
  cloudStorageConsent Boolean   @default(false)
  schemaVersion       Int       @default(1)
  endedAt             DateTime?
  turnCount           Int       @default(0)
  charCount           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  user    User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payload InterpreterCloudSessionPayload?

  @@unique([userId, clientSessionId])
  @@index([userId, updatedAt])
  @@index([userId, deletedAt])
  @@index([organizationId])
  @@index([practiceProfileId])
}

/// Encrypted turn payload — no audio columns.
model InterpreterCloudSessionPayload {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  userId         String
  payloadEnc     String   @db.Text
  payloadVersion Int      @default(1)
  checksumSha256 String?  @db.VarChar(64)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session InterpreterCloudSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// B2B Medical Interpreter — hashed invite tokens for QR/link entry (Phase 4.6+).
/// No patient transcript or session content stored on this model.
model PracticeInterpreterInvite {
  id                String    @id @default(cuid())
  practiceProfileId String
  createdByUserId   String
  displayName       String?   @db.VarChar(80)
  /// waiting_room | reception | doctor_room | remote | other
  inviteType        String    @db.VarChar(32)
  /// SHA-256 hex of raw token — plaintext token never stored.
  tokenHash         String    @unique
  /// First 8 chars of token for staff list identification only.
  tokenPrefix       String?   @db.VarChar(12)
  status            String    @default("active")
  expiresAt         DateTime
  revokedAt         DateTime?
  revokedByUserId   String?
  maxUses           Int?
  usageCount        Int       @default(0)
  metadataVersion   String    @default("interpreter-invite-v1") @db.VarChar(32)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile PracticeProfile                  @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  createdBy       User                             @relation("InterpreterInviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  revokedBy       User?                            @relation("InterpreterInviteRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  usages          PracticeInterpreterInviteUsage[]
  sessionLinks    PracticeInterpreterSessionLink[]

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, createdAt])
  @@index([status, expiresAt])
}

/// Optional usage audit — IP hash only; no patient linkage in Phase 4.6.
model PracticeInterpreterInviteUsage {
  id       String   @id @default(cuid())
  inviteId String
  usedAt   DateTime @default(now())
  ipHash   String?  @db.VarChar(64)

  invite PracticeInterpreterInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId, usedAt])
}

/// B2B — patient consent link between practice and interpreter session (Phase 4).
/// No audio; conversation documentation only after explicit patient consent.
model PracticeInterpreterSessionLink {
  id                String    @id @default(cuid())
  practiceProfileId String
  patientUserId     String
  inviteId          String?
  /// Client-side interpreter session UUID.
  clientSessionId   String    @db.VarChar(36)
  consentRecordId   String?
  /// pending | granted | revoked
  consentStatus     String    @default("pending")
  consentGrantedAt  DateTime?
  consentRevokedAt  DateTime?
  revokedByUserId   String?
  metadataVersion   String    @default("interpreter-practice-link-v1") @db.VarChar(32)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile PracticeProfile                  @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  patientUser     User                             @relation("InterpreterSessionLinkPatient", fields: [patientUserId], references: [id], onDelete: Cascade)
  invite          PracticeInterpreterInvite?       @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  revokedBy       User?                            @relation("InterpreterSessionLinkRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  payload         PracticeInterpreterSharePayload?

  @@unique([practiceProfileId, patientUserId, clientSessionId])
  @@index([practiceProfileId, consentStatus])
  @@index([practiceProfileId, consentGrantedAt])
  @@index([patientUserId, consentStatus])
}

/// Encrypted conversation documentation shared with practice (no audio).
model PracticeInterpreterSharePayload {
  id              String   @id @default(cuid())
  linkId          String   @unique
  payloadEnc      String   @db.Text
  checksumSha256  String   @db.VarChar(64)
  schemaVersion   Int
  turnCount       Int
  charCount       Int
  patientLanguage String   @db.VarChar(16)
  doctorLanguage  String   @db.VarChar(16)
  sessionStatus   String   @db.VarChar(16)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  link PracticeInterpreterSessionLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
}

/// Patient-owned vaccination record — self-reported, not an official proof.
/// No medical interpretation; stores what the patient manually enters.
model VaccinationEntry {
  id              String    @id @default(cuid())
  userId          String
  vaccineName     String    @db.VarChar(200)
  disease         String    @db.VarChar(200)
  vaccinationDate DateTime  @db.Date
  doseLabel       String?   @db.VarChar(80)
  lotNumber       String?   @db.VarChar(80)
  location        String?   @db.VarChar(200)
  nextDueDate     DateTime? @db.Date
  notes           String?   @db.Text
  documentKey     String?   @db.VarChar(500)
  documentName    String?   @db.VarChar(200)
  documentMime    String?   @db.VarChar(80)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, vaccinationDate])
  @@index([userId, deletedAt])
}

/// Patient-recorded vital measurements — manual entry, not an official medical record.
model VitalEntry {
  id             String    @id @default(cuid())
  userId         String
  /// blood_pressure | heart_rate | glucose | weight | oxygen | temperature
  type           String    @db.VarChar(40)
  /// Primary value (systolic for BP, bpm, mg/dL, kg, %, °C)
  valuePrimary   Float
  /// Secondary value — diastolic mmHg for blood_pressure only
  valueSecondary Float?
  /// mmHg | bpm | mg/dL | mmol/L | kg | % | °C
  unit           String    @db.VarChar(20)
  measuredAt     DateTime
  notes          String?   @db.Text
  /// manual | import
  source         String    @default("manual") @db.VarChar(40)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, measuredAt])
  @@index([userId, deletedAt])
}

/// Patient-recorded allergy — structured entry, not an official medical record.
model AllergyEntry {
  id            String    @id @default(cuid())
  userId        String
  /// Name of allergen — e.g. "Penicillin", "Peanuts", "Latex"
  allergen      String    @db.VarChar(200)
  /// medication | food | environmental | insect | contact | other
  allergyType   String    @db.VarChar(40)
  /// mild | moderate | severe | life_threatening
  severity      String    @db.VarChar(40)
  /// Free-text description of the reaction — e.g. "Anaphylaxis, throat swelling"
  reaction      String?   @db.Text
  diagnosedDate DateTime?
  /// active | inactive | uncertain
  status        String    @default("active") @db.VarChar(40)
  notes         String?   @db.Text
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, deletedAt])
}

/// Patient-recorded diagnosis / medical history — structured entry, not an official medical record.
model DiagnosisEntry {
  id             String    @id @default(cuid())
  userId         String
  /// Condition name — e.g. "Diabetes mellitus Typ 2", "Hypertension"
  conditionName  String    @db.VarChar(300)
  /// ICD-10 code — optional, e.g. "E11", "I10"
  icdCode        String?   @db.VarChar(20)
  diagnosedDate  DateTime?
  /// active | chronic | resolved | managed | uncertain
  status         String    @default("active") @db.VarChar(40)
  /// Treating doctor or clinic name — organizational only
  treatingDoctor String?   @db.VarChar(200)
  notes          String?   @db.Text
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, deletedAt])
}

/**
 * Simulated e-Rezept entry — practice issues, patient redeems at pharmacy. No real TI crypto.
 */
model ErezeptEntry {
  id             String @id @default(cuid())
  /// Patient user (receiver)
  patientUserId  String
  /// Practice user who issued (actor)
  issuedByUserId String
  /// PracticePatientLink for consent + scope
  linkId         String

  medicationName String    @db.VarChar(300)
  icdCode        String?   @db.VarChar(20)
  dosage         String?   @db.VarChar(200)
  instructions   String?   @db.Text
  /// Simulated token code — e.g. "ERZ-A1B2-C3D4-E5F6"
  tokenCode      String    @db.VarChar(40)
  /// issued | at_pharmacy | redeemed | expired | cancelled
  status         String    @default("issued") @db.VarChar(40)
  issuedAt       DateTime  @default(now())
  /// Default 28 days validity per §16 AMVV
  validUntil     DateTime
  redeemedAt     DateTime?
  notes          String?   @db.Text
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  patient  User @relation("PatientErezept", fields: [patientUserId], references: [id], onDelete: Cascade)
  issuedBy User @relation("PracticeErezept", fields: [issuedByUserId], references: [id], onDelete: Cascade)

  @@index([patientUserId, status])
  @@index([patientUserId, deletedAt])
  @@index([linkId])
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model SosCard {
  id            String @id @default(cuid())
  /// One card per patient — create-or-upsert pattern
  patientUserId String @unique

  /// Blood type: A+, A-, B+, B-, AB+, AB-, 0+, 0-
  bloodType String? @db.VarChar(10)

  /// Emergency contacts
  emergencyContact1Name  String? @db.VarChar(120)
  emergencyContact1Phone String? @db.VarChar(40)
  emergencyContact2Name  String? @db.VarChar(120)
  emergencyContact2Phone String? @db.VarChar(40)

  /// Free-text note for first responders (max ~500 chars)
  firstResponderNote String? @db.Text

  /// AI-generated emergency summary (gpt-4o-mini, stored on save)
  aiSummary          String?   @db.Text
  aiSummaryUpdatedAt DateTime?

  /// Public QR share token — nullable = not shared; UUID generated on demand
  publicToken          String?   @unique @db.VarChar(80)
  tokenGeneratedAt     DateTime?
  /// Optional expiry for the public token — when set and in the past, public access is denied
  publicTokenExpiresAt DateTime?

  /// Patient-entered medication list — JSON array [{ name, dose?, frequency?, instruction?, note? }]. Self-reported.
  medicationsJson Json?
  /// Patient-entered implant/device list — JSON array [{ name, bodyRegion?, manufacturer?, note? }]. Self-reported.
  implantsJson    Json?

  /// Medically-relevant biological sex — self-reported, voluntary emergency datum (NOT a gender/identity field;
  /// distinct from the non-clinical UserProfile.gender). MALE | FEMALE | DIVERSE_INTERSEX | UNKNOWN | PREFER_NOT_TO_SAY
  emergencyBiologicalSex String? @db.VarChar(20)

  /// Pregnancy status — sensitive, voluntary, opt-in visibility. UNKNOWN | NO | YES | NOT_APPLICABLE | PREFER_NOT_TO_SAY
  pregnancyStatus String? @db.VarChar(20)

  /// Preferred language for the public emergency view: de | en | fr | es | it
  preferredEmergencyLanguage String? @db.VarChar(5)

  /// Field-level visibility flags for the PUBLIC emergency page.
  /// Defaults preserve current behaviour; sensitive/identifying fields default to opt-in (false).
  showBloodType          Boolean @default(true)
  showAge                Boolean @default(true)
  showDateOfBirth        Boolean @default(false)
  showBiologicalSex      Boolean @default(true)
  showHeight             Boolean @default(true)
  showWeight             Boolean @default(true)
  showAllergies          Boolean @default(true)
  showDiagnoses          Boolean @default(true)
  showMedications        Boolean @default(true)
  showImplants           Boolean @default(true)
  showPregnancyStatus    Boolean @default(false)
  showEmergencyContacts  Boolean @default(true)
  showFirstResponderNote Boolean @default(true)
  showAiSummary          Boolean @default(true)
  showPreferredLanguage  Boolean @default(true)

  /// Soft delete — when set, the card is treated as absent everywhere (patient, practice, public).
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient User @relation(fields: [patientUserId], references: [id], onDelete: Cascade)

  @@index([publicToken])
}

/**
 * Meda Realtime session metadata for the B2B practice area — NOT YET ACTIVE.
 * Enable only via MEDA_CLOUD_ARCHIVE_ENABLED flag.
 * Stores organizational metadata only — no turn text, no audio, no API keys, no debug events.
 */
model PracticeMedaSession {
  id                    String    @id @default(cuid())
  practiceProfileId     String?
  /// MedScoutX user ID of the patient — optional (session may be for unregistered patient)
  patientUserId         String?
  practicePatientLinkId String?
  /// User ID of the practice staff member who started the session
  createdByUserId       String?
  /// Reference to ConsentRecord — must be set before any content is stored
  consentRecordId       String?
  startedAt             DateTime
  endedAt               DateTime?
  patientLanguage       String    @db.VarChar(12)
  practiceLanguage      String    @db.VarChar(12)
  durationSeconds       Int?
  /// none | local | cloud
  storageMode           String    @default("none") @db.VarChar(20)
  /// started | completed | cancelled | deleted
  status                String    @default("started") @db.VarChar(20)
  /// Reference to future PracticeArchiveDocument row — storageKey points to Object Storage
  pdfDocumentId         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  practiceProfile     PracticeProfile?     @relation(fields: [practiceProfileId], references: [id], onDelete: SetNull)
  practicePatientLink PracticePatientLink? @relation(fields: [practicePatientLinkId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, startedAt])
  @@index([patientUserId])
  @@index([practicePatientLinkId])
  @@index([deletedAt])
}

/// Anamnesis questionnaire template belonging to a verified practice.
model PracticeAnamnesisTemplate {
  id                String   @id @default(cuid())
  practiceProfileId String
  /// Multilingual title — JSON {de, en, fr, it, es}
  titleJson         Json
  /// Multilingual description — JSON {de, en, fr, it, es}
  descriptionJson   Json?
  /// active | archived
  status            String   @default("active") @db.VarChar(20)
  /// Display order among templates of the same practice
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  practiceProfile PracticeProfile               @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  sections        PracticeAnamnesisSection[]
  questions       PracticeAnamnesisQuestion[]
  links           PracticeAnamnesisLink[]
  submissions     PracticeAnamnesisSubmission[]

  @@index([practiceProfileId, status])
}

/// Section / step grouping questions inside one template.
model PracticeAnamnesisSection {
  id         String   @id @default(cuid())
  templateId String
  /// Multilingual section title — JSON {de, en, fr, it, es}
  titleJson  Json
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template  PracticeAnamnesisTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions PracticeAnamnesisQuestion[]

  @@index([templateId])
}

/// Single question inside an anamnesis template section.
model PracticeAnamnesisQuestion {
  id                String   @id @default(cuid())
  templateId        String
  /// Nullable — null means the question belongs directly to the template (legacy)
  sectionId         String?
  /// text | textarea | single_choice | multi_choice | date | number | yes_no
  type              String   @db.VarChar(30)
  /// Multilingual label — JSON {de, en, fr, it, es}
  labelJson         Json
  /// Multilingual hint / placeholder — JSON {de, en, fr, it, es}
  hintJson          Json?
  /// Multilingual options for choice types — JSON [{de, en, fr, it, es}, …]
  optionsJson       Json?
  isRequired        Boolean  @default(false)
  /// Max character count for text/textarea answers — null means runtime default (500)
  responseMaxLength Int?
  /// Display order within section
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  template PracticeAnamnesisTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  section  PracticeAnamnesisSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([sectionId])
}

/// Shareable QR / link token for a specific anamnesis template.
/// Raw token (64 hex chars) never stored — only its SHA-256 hash.
model PracticeAnamnesisLink {
  id                String    @id @default(cuid())
  practiceProfileId String
  templateId        String
  createdByUserId   String?
  /// SHA-256 hex of raw 32-byte random token — plaintext never stored.
  tokenHash         String    @unique @db.VarChar(64)
  /// First 8 chars of raw token for staff list display only.
  tokenPrefix       String?   @db.VarChar(12)
  label             String?   @db.VarChar(120)
  isActive          Boolean   @default(true)
  expiresAt         DateTime?
  disabledAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  practiceProfile      PracticeProfile               @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  template             PracticeAnamnesisTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy            User?                         @relation("AnamnesisLinkCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  submissions          PracticeAnamnesisSubmission[]
  bookingSettingsLinks PracticeBookingSettings[]

  @@index([practiceProfileId, isActive])
  @@index([practiceProfileId, createdAt])
  @@index([templateId])
}

/// Patient-submitted anamnesis form — answers captured after explicit consent.
/// answersJson is a snapshot: [{questionId, sectionId, sectionLabel, questionLabel, type, value}]
model PracticeAnamnesisSubmission {
  id                        String    @id @default(cuid())
  practiceProfileId         String
  templateId                String
  /// Optional link that was used — null if submitted via a now-deleted link.
  linkId                    String?
  /// BCP-47 language tag selected by patient (de, en, fr, it, es).
  patientLanguage           String    @db.VarChar(12)
  /// BCP-47 language tag of the practice/doctor (for future translation prep).
  doctorLanguage            String?   @db.VarChar(12)
  /// Patient personal data: firstName, lastName, dateOfBirth, email, phone, insuranceType, insuranceName, insuranceNumber.
  patientInfoJson           Json?
  /// Snapshot of answers with label text in patient's language.
  answersJson               Json
  /// Timestamp when patient actively granted DSGVO consent.
  consentGrantedAt          DateTime
  consentVersion            String    @default("v1") @db.VarChar(20)
  /// JSON array of consent scope strings granted by patient.
  consentScopes             Json?
  submittedAt               DateTime  @default(now())
  /// new | viewed | archived | deleted
  status                    String    @default("new") @db.VarChar(20)
  viewedAt                  DateTime?
  archivedAt                DateTime?
  deletedAt                 DateTime?
  /// AI-generated translations — same structure as answersJson with translatedText per item.
  translatedAnswersJson     Json?
  /// pending | completed | failed | unavailable | skipped
  translationStatus         String?   @db.VarChar(20)
  translatedAt              DateTime?
  /// BCP-47 target language used for translation (doctor/practice language).
  translationTargetLanguage String?   @db.VarChar(12)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  practiceProfile PracticeProfile           @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  template        PracticeAnamnesisTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  link            PracticeAnamnesisLink?    @relation(fields: [linkId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId, status])
  @@index([practiceProfileId, submittedAt])
  @@index([templateId])
  @@index([linkId])
  @@index([deletedAt])
}

/// Practice booking configuration — internal appointment-request module only.
/// No external links, no redirect logic. bookingMode: "disabled" | "medscoutx_request".
model PracticeBookingSettings {
  id                String @id @default(cuid())
  practiceProfileId String @unique

  /// Whether the practice has activated inbound appointment requests.
  /// Only owner/admin may set this to true via the settings API.
  bookingEnabled Boolean @default(false)

  /// "disabled" = requests not accepted (default).
  /// "medscoutx_request" = patients with an active PracticePatientLink may submit a request.
  bookingMode String @default("disabled") @db.VarChar(30)

  /// Optional guidance text shown to patients in the request form (no medical content).
  requestFormNote String? @db.VarChar(300)

  /// Optional reference to an existing anamnesis link shown after a request is accepted.
  /// Set to null automatically when the referenced link is deleted (onDelete: SetNull).
  linkedAnamnesisLinkId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practiceProfile     PracticeProfile        @relation(fields: [practiceProfileId], references: [id], onDelete: Cascade)
  linkedAnamnesisLink PracticeAnamnesisLink? @relation(fields: [linkedAnamnesisLinkId], references: [id], onDelete: SetNull)

  @@index([practiceProfileId])
}

// ─── Billing Plausibility (Phase D) ──────────────────────────────────────────
// Append-only plausibility review sessions for GOÄ/PKV billing hints.
// NOT a certified billing system. NOT legally binding. No patient identifiers stored.
// Scalar FKs (no Prisma-level relation to PracticeProfile) to keep this module
// fully additive without touching existing model definitions.

/**
 * One review session = one submitted set of GOÄ rows.
 * status: pending | reviewed | dismissed
 * sourceType: manual (user entered) — upload/api reserved for future phases.
 * disclaimerVersion: semver of the disclaimer text shown at submission time.
 * inputSummaryJson: row count and ziffern list (no patient data).
 * resultSummaryJson: deterministic warnings per row (no AI in Phase D).
 */
model BillingPlausibilitySession {
  id                String    @id @default(cuid())
  /// Indexed scalar FK — no Prisma relation to avoid touching PracticeProfile model.
  practiceProfileId String
  createdByUserId   String
  /// pending | reviewed | dismissed
  status            String    @default("pending") @db.VarChar(20)
  /// manual | upload | api
  sourceType        String    @default("manual") @db.VarChar(20)
  /// { rowCount: number, ziffern: string[] } — no patient identifiers.
  inputSummaryJson  Json
  /// { warnings: WarningsByRow[] } from deterministic catalogue checks — no AI.
  resultSummaryJson Json?
  /// Semver of the disclaimer text accepted at submission time.
  disclaimerVersion String    @db.VarChar(20)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  dismissedAt       DateTime?

  items    BillingPlausibilityItem[]
  auditLog BillingPlausibilityAuditLog[]

  @@index([practiceProfileId, createdAt])
  @@index([practiceProfileId, status])
  @@index([createdByUserId])
}

/**
 * One row per GOÄ ziffer submitted in a session.
 * catalogueMatchJson: { found: bool, ziffer, title, points } — from static catalogue.
 * warningsJson: string[] — deterministic warning codes for this row.
 */
model BillingPlausibilityItem {
  id                 String   @id @default(cuid())
  sessionId          String
  ziffer             String   @db.VarChar(20)
  /// Stored as string to preserve the original input format (e.g. "2,3").
  factor             String   @db.VarChar(10)
  count              Int
  /// Free-text context entered by practitioner — no clinical/patient content enforced by route.
  contextText        String?  @db.VarChar(600)
  /// Result of catalogue lookup for this ziffer.
  catalogueMatchJson Json?
  /// Array of warning code strings for this row.
  warningsJson       Json?
  createdAt          DateTime @default(now())

  session BillingPlausibilitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([ziffer])
}

/**
 * Immutable audit trail for billing plausibility session lifecycle events.
 * action: created | dismissed | reviewed
 * metadataJson: { rowCount, ziffernList, ... } — no patient identifiers.
 */
model BillingPlausibilityAuditLog {
  id           String   @id @default(cuid())
  sessionId    String
  actorUserId  String?
  /// created | dismissed | reviewed
  action       String   @db.VarChar(40)
  metadataJson Json?
  createdAt    DateTime @default(now())

  session BillingPlausibilitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([actorUserId])
}
