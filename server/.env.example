# Copy to .env and fill in values — never commit real secrets.

DATABASE_URL=postgresql://user:password@localhost:5432/medscoutx
JWT_SECRET=change_me
OPENAI_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=MedScoutX <no-reply@example.com>
CORS_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Google Places API (server only — never expose in frontend)
GOOGLE_PLACES_API_KEY=your_key_here

# Optional: demo search results without API key (non-production only)
# PLACES_DEMO_MODE=true

# Auto-create "Medscout Klinik" test practice when account has none (default: on outside production)
# PRACTICE_DEMO_PROFILE_ENABLED=true

# Internal cron/worker (Render Cron → POST /api/internal/worker/run)
WORKER_CRON_SECRET=change_me_long_random
WORKER_ENABLED=false
# When WORKER_ENABLED=true, unset per-processor flags default to on:
# WORKER_WEBHOOKS_ENABLED=true
# WORKER_REMINDERS_ENABLED=true
# WORKER_EXPORTS_ENABLED=true
# WORKER_OCR_ENABLED=true
# WORKER_TELEMEDICINE_CLEANUP_ENABLED=true
REMINDER_WORKER_BATCH_SIZE=25
TELEMEDICINE_CLEANUP_BATCH_SIZE=50
# Optional organizational appointment emails (requires RESEND_API_KEY)
ENABLE_APPOINTMENT_EMAIL_REMINDERS=false

# Legacy practice integration webhooks (single URL per practice)
PRACTICE_WEBHOOK_HTTP_ENABLED=false

# Developer multi-endpoint webhooks
ENABLE_PRACTICE_WEBHOOKS=false
WEBHOOK_WORKER_BATCH_SIZE=30
