# Copy to .env and fill in values — never commit real secrets.

DATABASE_URL=postgresql://user:password@localhost:5432/medscoutx
JWT_SECRET=change_me
OPENAI_API_KEY=
# OpenAI defaults (all KI text/realtime unless overridden)
# OPENAI_CHAT_MODEL=gpt-5.4
# OPENAI_DEFAULT_MODEL=gpt-5.4
# Meda knowledge assistant widget (/api/meda/chat)
# MEDA_OPENAI_MODEL=gpt-5.4
RESEND_API_KEY=
EMAIL_FROM=MedScoutX <no-reply@example.com>
CORS_ORIGIN=http://localhost:5173
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Google Places API (server only — never expose in frontend)
# Enable "Places API (New)" on the key; Geocoding API is optional (address lookup uses Places text search).
GOOGLE_PLACES_API_KEY=your_key_here

# Optional: demo search results without API key (non-production only)
# PLACES_DEMO_MODE=true

# Auto-create "Medscout Klinik" test practice when account has none (default: on; set false to disable)
# PRACTICE_DEMO_PROFILE_ENABLED=false

# Internal cron/worker (Render Cron → POST /api/internal/worker/run)
WORKER_CRON_SECRET=change_me_long_random
WORKER_ENABLED=false
# When WORKER_ENABLED=true, unset per-processor flags default to on:
# WORKER_WEBHOOKS_ENABLED=true
# WORKER_REMINDERS_ENABLED=true
# WORKER_EXPORTS_ENABLED=true
# WORKER_OCR_ENABLED=true
# WORKER_TELEMEDICINE_CLEANUP_ENABLED=true
REMINDER_WORKER_BATCH_SIZE=25
TELEMEDICINE_CLEANUP_BATCH_SIZE=50
# Optional organizational appointment emails (requires RESEND_API_KEY)
ENABLE_APPOINTMENT_EMAIL_REMINDERS=false

# Legacy practice integration webhooks (single URL per practice)
PRACTICE_WEBHOOK_HTTP_ENABLED=false

# Developer multi-endpoint webhooks
ENABLE_PRACTICE_WEBHOOKS=false
WEBHOOK_WORKER_BATCH_SIZE=30

# Assistants (Symptom-Check, Körperkarte, Bildanalyse): set model gpt-5.4 in OpenAI dashboard for ASSISTANT_ID*

# ── Feature flags (set to true to enable) ──────────────────────────────────
CARE_RELATIONSHIP_ENABLED=false
MEDICATION_PLAN_V2=false
COMMUNICATION_V2=false
PATIENT_INBOX=false
PRACTICE_DOCUMENTS_V2=false
PRACTICE_INBOX=false
ENABLE_VITALS=false
ENABLE_VACCINATION_PASS=false
ENABLE_HEALTH_HISTORY=false
ENABLE_E_REZEPT=false
ENABLE_DOCUMENT_OCR=false
ENABLE_LAB_STRUCTURING=false
ENABLE_LAB_PATIENT_EXPLANATION=false
ENABLE_SOS_CARD=false
ENABLE_TELEMEDICINE=false
ENABLE_PRACTICE_CALENDAR=false
# GOÄ/PKV billing plausibility — automated hint only, not a legal billing decision.
# Set to true to enable the billing plausibility route and UI.
ENABLE_BILLING_PLAUSIBILITY=false
# Optional AI-assisted plausibility hints (Phase E — controlled staging pilot).
#
# Requirements before enabling in any non-local environment:
#   1. ENABLE_BILLING_PLAUSIBILITY=true   ← base flag must be on first
#   2. OPENAI_API_KEY must be set to a valid key with sufficient quota
#   3. Run: node scripts/verifyBillingPlausibility.js   ← all 19 sections must pass
#   4. Review staging checklist: docs/billing-ai-staging-checklist.md
#
# Safety guarantees (always active regardless of this flag):
#   - No patient-identifying fields are ever sent to OpenAI
#   - All AI output is scanned for forbidden medical/legal claims before persistence
#   - nonBinding: true is enforced; any AI response missing this field falls back
#   - Falls back to deterministic hints silently if OpenAI is unavailable
#
# Never enable in production without completing the staging checklist.
ENABLE_BILLING_AI_REVIEW=false
#
# Billing plausibility data retention (Phase D5) — POLICY GUIDANCE ONLY.
# Recommended retention period for billing plausibility sessions, in days.
# This value is documentation only: NO automatic purge runs. Retention is enforced
# manually by an operator running:
#   npm run billing:purge -- --days=180 --dryRun        (review first)
#   npm run billing:purge -- --days=180 --confirmPurge   (then, if approved)
# The purge script REQUIRES an explicit --days=N and never reads this variable.
# A scheduled job (Render cron) may be added later ONLY after legal approves the
# retention period.
BILLING_SESSION_RETENTION_DAYS=180

# =====================================================================
# SOS Notfallausweis — Wallet integration (Phase 3 PREPARATION ONLY)
# =====================================================================
# All wallet credentials are SERVER-ONLY and must NEVER be exposed to the frontend/bundle.
# Wallet is OPTIONAL: if these are unset, the wallet buttons stay disabled and the
# status endpoint reports the provider as unavailable. Nothing here is required at startup.
# The wallet QR encodes ONLY the existing public emergency URL (FRONTEND_URL + /emergency/:token);
# never health data. FRONTEND_URL (above) is reused to build that URL.
#
# --- Apple Wallet (.pkpass) ---
# Requires the `passkit-generator` library:  cd server && npm install passkit-generator
# APPLE_WALLET_PASS_TYPE_ID=pass.com.example.medscoutx.sos
# APPLE_WALLET_TEAM_ID=
# APPLE_WALLET_CERT_PEM=          # Pass Type ID certificate (PEM)
# APPLE_WALLET_CERT_KEY_PEM=      # private key (PEM) — server only
# APPLE_WALLET_WWDR_PEM=          # Apple WWDR intermediate certificate (PEM)
# APPLE_WALLET_CERT_KEY_PASSPHRASE=   # optional — only if the private key is passphrase-protected
# APPLE_WALLET_ORGANIZATION_NAME=MedScoutX   # optional — defaults to "MedScoutX"
#
# --- Google Wallet (Generic pass + signed JWT) ---
# GOOGLE_WALLET_ISSUER_ID=
# GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=   # service account credentials JSON — server only
# GOOGLE_WALLET_CLASS_ID=               # generic pass class id
