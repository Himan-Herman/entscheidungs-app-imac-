# ─── E2E test environment — local configuration ─────────────────────────────
#
# Copy this file to .env.e2e (gitignored) and fill in your local values.
# Never commit .env.e2e — it contains test credentials.
#
# .env.e2e is loaded automatically by playwright.config.js when running E2E
# tests locally. Values already set in the shell are NOT overridden.
#
# ─── Step 1: Create a local test fixture ─────────────────────────────────────
#
#   npm run e2e:fixture:create
#   (or: node e2e/helpers/createE2eTestUser.js)
#
#   The script will print the E2E_TEST_EMAIL and E2E_TEST_PASSWORD values to
#   copy into this file. Run it once; idempotent on repeat.
#
# ─── Step 2: Fill in values below ────────────────────────────────────────────

# Email of the E2E test practice owner created by e2e:fixture:create.
E2E_TEST_EMAIL=

# Password for the E2E test practice owner.
E2E_TEST_PASSWORD=

# Frontend base URL (default: http://localhost:5173 — only override if non-default).
# PLAYWRIGHT_BASE_URL=http://localhost:5173

# ─── Required server/.env settings (not this file) ───────────────────────────
#
# These must be set in server/.env (or the shell) before starting the server:
#
#   DATABASE_URL=postgresql://localhost/medscoutx_dev   ← local DB, never production
#   JWT_SECRET=any-local-secret-value
#   ENABLE_BILLING_PLAUSIBILITY=true
#   ENABLE_BILLING_AI_REVIEW=false
#
# ─── Running the E2E tests ───────────────────────────────────────────────────
#
#   # Terminal 1 — backend:
#   cd server && node app.js
#
#   # Terminal 2 — frontend:
#   cd client && npm run dev
#
#   # Terminal 3 — E2E:
#   npm run test:e2e
#
# ─── Playwright browser installation (one-time) ──────────────────────────────
#
#   npm run test:e2e:install   # installs Chromium browser binary
#
# ─── Cleanup fixture after testing ───────────────────────────────────────────
#
#   npm run e2e:fixture:cleanup
